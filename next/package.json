{
  "name": "dsa-coach-next",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config apps/web/vite.config.ts",
    "test": "bun test",
    "verify:content": "bun run src/cli/verify-content.ts",
    "inventory:legacy": "bun run scripts/legacy-inventory.ts",
    "coverage:translations": "bun run scripts/report-translation-coverage.ts",
    "setup:toolchains": "bun run scripts/setup-toolchains.ts",
    "setup:lsp": "bun run scripts/setup-lsp.ts",
    "check:lsp": "bun run scripts/setup-lsp.ts --check",
    "verify:lsp": "bun run scripts/verify-lsp.ts",
    "verify:lsp:fast": "bun run scripts/verify-lsp.ts --languages=typescript,python,go",
    "verify:runner-backends": "bun run scripts/verify-runner-backends.ts",
    "verify:sandbox": "bun run scripts/verify-sandbox.ts",
    "migrate:legacy-batch": "bun run scripts/migrate-legacy-batch.ts",
    "daemon": "bun run src/cli/runner-daemon.ts",
    "desktop:host": "bun run src/cli/desktop-host.ts",
    "package:mac": "bun run scripts/package-macos.ts",
    "web:dev": "vite --host 127.0.0.1 --config apps/web/vite.config.ts",
    "web:preview": "vite preview --host 127.0.0.1 --config apps/web/vite.config.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@vitejs/plugin-react": "^4.3.4",
    "pyright": "^1.1.409",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "typescript-language-server": "^5.3.0",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.10.2"
  }
}
