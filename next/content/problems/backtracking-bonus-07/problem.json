{
  "id": "backtracking-bonus-07",
  "kind": "problem",
  "title": "Count N-Queens Arrangements",
  "difficulty": "medium",
  "concepts": [
    "backtracking",
    "constraints",
    "recursion tree"
  ],
  "prompt": "Return how many ways n queens can be placed on an n-by-n chessboard so that no two queens attack each other. Two queens attack if they share a row, a column, or a diagonal.",
  "signature": {
    "name": "countNQueens",
    "inputs": [
      {
        "name": "n",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "four by four",
      "args": [
        4
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "one by one",
      "args": [
        1
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "zero board",
      "args": [
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "two by two",
      "args": [
        2
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "three by three",
      "args": [
        3
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "five by five",
      "args": [
        5
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "six by six",
      "args": [
        6
      ],
      "expected": 4,
      "visibility": "hidden"
    }
  ],
