      "referencePath": "problems/aoc-y2-d2-cipher-check/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "valid_cipher_count",
      "starterPath": "problems/aoc-y2-d2-cipher-check/solutions/scala/starter.scala",
      "referencePath": "problems/aoc-y2-d2-cipher-check/solutions/scala/reference.scala"
    }
  }
}
