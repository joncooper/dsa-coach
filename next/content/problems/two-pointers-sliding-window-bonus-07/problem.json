{
  "id": "two-pointers-sliding-window-bonus-07",
  "kind": "problem",
  "title": "Shortest Subarray At Least Target",
  "difficulty": "medium",
  "concepts": [
    "two-pointers-sliding-window",
    "variable window"
  ],
  "prompt": "All values are positive. Return the length of the shortest contiguous subarray whose sum is greater than or equal to target. If no subarray qualifies, return 0.",
  "signature": {
    "name": "minWindowForSum",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "target",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "tight window",
      "args": [
        [
          2,
          3,
          1,
          2,
          4,
          3
        ],
        7
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "impossible",
      "args": [
        [
          1,
          1,
          1,
          1
        ],
        10
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        3
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single suffices",
      "args": [
        [
          5
        ],
        5
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "whole array needed",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        10
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "exact pair",
      "args": [
        [
          4,
          4
        ],
        4
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "big value at end",
      "args": [
        [
          1,
          1,
          1,
          7
        ],
        7
      ],
      "expected": 1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "min_window_for_sum",
      "starterPath": "problems/two-pointers-sliding-window-bonus-07/solutions/python/starter.py",
      "referencePath": "problems/two-pointers-sliding-window-bonus-07/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "minWindowForSum",
      "starterPath": "problems/two-pointers-sliding-window-bonus-07/solutions/typescript/starter.ts",
      "referencePath": "problems/two-pointers-sliding-window-bonus-07/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MinWindowForSum",
      "starterPath": "problems/two-pointers-sliding-window-bonus-07/solutions/go/starter.go",
      "referencePath": "problems/two-pointers-sliding-window-bonus-07/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "minWindowForSum",
      "starterPath": "problems/two-pointers-sliding-window-bonus-07/solutions/scala/starter.scala",
      "referencePath": "problems/two-pointers-sliding-window-bonus-07/solutions/scala/reference.scala"
    }
  }
}
