{
  "id": "trees-graphs-bonus-05",
  "kind": "problem",
  "title": "Binary Tree Right Side View",
  "difficulty": "medium",
  "concepts": [
    "trees-graphs",
    "BFS",
    "level-order traversal"
  ],
  "prompt": "Given the root of a binary tree, imagine standing to its right. Return the values of the nodes you can see, ordered from top to bottom — that is, the last node at each depth.",
  "signature": {
    "name": "rightSideView",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number",
            "nullable": true
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "mixed shape",
      "args": [
        [
          1,
          2,
          3,
          null,
          5,
          null,
          4
        ]
      ],
      "expected": [
        1,
        3,
        4
      ],
      "visibility": "visible"
    },
    {
      "name": "single node",
      "args": [
        [
          9
        ]
      ],
      "expected": [
        9
      ],
      "visibility": "visible"
    },
    {
      "name": "empty tree",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "left chain only",
      "args": [
        [
          1,
          2,
          null,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "right chain only",
      "args": [
        [
          1,
          null,
          2,
          null,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "full tree",
      "args": [
        [
          1,
          2,
          3,
          4,
          5,
          6,
          7
        ]
      ],
      "expected": [
        1,
        3,
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "deep left visible",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": [
        1,
        3,
        4
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "right_side_view",
      "starterPath": "problems/trees-graphs-bonus-05/solutions/python/starter.py",
      "referencePath": "problems/trees-graphs-bonus-05/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "rightSideView",
      "starterPath": "problems/trees-graphs-bonus-05/solutions/typescript/starter.ts",
      "referencePath": "problems/trees-graphs-bonus-05/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "RightSideView",
      "starterPath": "problems/trees-graphs-bonus-05/solutions/go/starter.go",
      "referencePath": "problems/trees-graphs-bonus-05/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "rightSideView",
      "starterPath": "problems/trees-graphs-bonus-05/solutions/scala/starter.scala",
      "referencePath": "problems/trees-graphs-bonus-05/solutions/scala/reference.scala"
    }
  }
}
