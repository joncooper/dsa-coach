{
  "id": "binary-search-bonus-08",
  "kind": "problem",
  "title": "Split Array Largest Sum",
  "difficulty": "medium",
  "concepts": [
    "binary-search",
    "answer search",
    "feasibility"
  ],
  "prompt": "Split the list into exactly k non-empty contiguous parts. Each part has a sum. Return the smallest possible value of the largest part sum.",
  "signature": {
    "name": "splitArrayMinLargest",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "k",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three parts",
      "args": [
        [
          7,
          2,
          5,
          10,
          8
        ],
        2
      ],
      "expected": 18,
      "visibility": "visible"
    },
    {
      "name": "two parts",
      "args": [
        [
          1,
          2,
          3,
          4,
          5
        ],
        2
      ],
      "expected": 9,
      "visibility": "visible"
    },
    {
      "name": "one part is whole sum",
      "args": [
        [
          1,
          4,
          4
        ],
        1
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "k equals length",
      "args": [
        [
          1,
          4,
          4
        ],
        3
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "single element",
      "args": [
        [
          9
        ],
        1
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          5,
          5,
          5,
          5
        ],
        2
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "zeros present",
      "args": [
        [
          0,
          0,
          0,
          7
        ],
        2
      ],
      "expected": 7,
      "visibility": "hidden"
    },
    {
      "name": "many small parts",
      "args": [
        [
          2,
          3,
          1,
          2,
          4,
          3
        ],
        3
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "max dominates",
      "args": [
        [
          1,
          1,
          1,
          20
        ],
        2
      ],
      "expected": 20,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "split_array_min_largest",
      "starterPath": "problems/binary-search-bonus-08/solutions/python/starter.py",
      "referencePath": "problems/binary-search-bonus-08/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "splitArrayMinLargest",
      "starterPath": "problems/binary-search-bonus-08/solutions/typescript/starter.ts",
      "referencePath": "problems/binary-search-bonus-08/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "SplitArrayMinLargest",
      "starterPath": "problems/binary-search-bonus-08/solutions/go/starter.go",
      "referencePath": "problems/binary-search-bonus-08/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "splitArrayMinLargest",
      "starterPath": "problems/binary-search-bonus-08/solutions/scala/starter.scala",
      "referencePath": "problems/binary-search-bonus-08/solutions/scala/reference.scala"
    }
  }
}
