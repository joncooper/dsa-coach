{
  "id": "linked-lists-bonus-04",
  "kind": "problem",
  "title": "Reverse Linked List",
  "difficulty": "easy",
  "concepts": [
    "linked-lists",
    "in-place updates",
    "pointer rewiring"
  ],
  "prompt": "Given the head of a singly linked list, reverse it in place and return the head of the reversed list.",
  "signature": {
    "name": "reverseList",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "four nodes",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": [
        4,
        3,
        2,
        1
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "visible"
    },
    {
      "name": "single",
      "args": [
        [
          7
        ]
      ],
      "expected": [
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "two nodes",
      "args": [
        [
          1,
          2
        ]
      ],
      "expected": [
        2,
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          5,
          5,
          5
        ]
      ],
      "expected": [
        5,
        5,
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "with negatives",
      "args": [
        [
          -1,
          2,
          -3
        ]
      ],
      "expected": [
        -3,
        2,
        -1
      ],
      "visibility": "hidden"
    },
    {
      "name": "already palindromic",
      "args": [
        [
          1,
          2,
          1
        ]
      ],
      "expected": [
        1,
        2,
        1
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "reverse_list",
      "starterPath": "problems/linked-lists-bonus-04/solutions/python/starter.py",
      "referencePath": "problems/linked-lists-bonus-04/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "reverseList",
      "starterPath": "problems/linked-lists-bonus-04/solutions/typescript/starter.ts",
      "referencePath": "problems/linked-lists-bonus-04/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "ReverseList",
      "starterPath": "problems/linked-lists-bonus-04/solutions/go/starter.go",
      "referencePath": "problems/linked-lists-bonus-04/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "reverseList",
      "starterPath": "problems/linked-lists-bonus-04/solutions/scala/starter.scala",
      "referencePath": "problems/linked-lists-bonus-04/solutions/scala/reference.scala"
    }
  }
}
