          1,
          2,
          3
        ]
      ],
      "expected": [
        [],
        [
          1
        ],
        [
          1,
          2
        ],
        [
          1,
          2,
          3
        ],
        [
          1,
          3
        ],
        [
          2
        ],
        [
          2,
          3
        ],
        [
          3
        ]
      ],
      "visibility": "hidden"
    },
    {
      "name": "two reversed",
      "args": [
        [
          3,
          1
        ]
      ],
      "expected": [
        [],
        [
          1
        ],
        [
          1,
