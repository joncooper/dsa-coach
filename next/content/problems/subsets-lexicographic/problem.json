{
  "id": "subsets-lexicographic",
  "kind": "problem",
  "title": "Subsets Lexicographic",
  "difficulty": "medium",
  "concepts": [
    "backtracking",
    "subsets"
  ],
  "prompt": "Given distinct integers, return all subsets. Sort the input first and return subsets in DFS order where each subset is copied when visited.",
  "signature": {
    "name": "subsetsLexicographic",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    }
  },
  "tests": [
    {
      "name": "two",
      "args": [
        [
          2,
          1
        ]
      ],
      "expected": [
        [],
        [
          1
        ],
        [
          1,
          2
        ],
        [
          2
        ]
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [
        []
      ],
      "visibility": "visible"
    },
    {
      "name": "one",
      "args": [
        [
          5
        ]
      ],
      "expected": [
        [],
        [
          5
        ]
      ],
      "visibility": "hidden"
    },
    {
      "name": "three count shape",
      "args": [
