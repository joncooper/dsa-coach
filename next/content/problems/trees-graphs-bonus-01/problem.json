{
  "id": "trees-graphs-bonus-01",
  "kind": "problem",
  "title": "Sum Of Tree Values",
  "difficulty": "warmup",
  "concepts": [
    "trees-graphs",
    "tree recursion",
    "DFS"
  ],
  "prompt": "Given the root of a binary tree, return the sum of the values stored in every node of the tree.",
  "signature": {
    "name": "treeValueSum",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number",
            "nullable": true
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "balanced tree",
      "args": [
        [
          5,
          4,
          8,
          11,
          null,
          13,
          4
        ]
      ],
      "expected": 45,
      "visibility": "visible"
    },
    {
      "name": "single node",
      "args": [
        [
          7
        ]
      ],
      "expected": 7,
      "visibility": "visible"
    },
    {
      "name": "empty tree",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "all negative",
      "args": [
        [
          -2,
          -1,
          -3
        ]
      ],
      "expected": -6,
      "visibility": "hidden"
    },
    {
      "name": "left chain",
      "args": [
        [
          1,
          2,
          null,
          3
        ]
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "mixed signs",
      "args": [
        [
          0,
          -5,
          5,
          10
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "zeros",
      "args": [
        [
          0,
          0,
          0
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "tree_value_sum",
      "starterPath": "problems/trees-graphs-bonus-01/solutions/python/starter.py",
      "referencePath": "problems/trees-graphs-bonus-01/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "treeValueSum",
      "starterPath": "problems/trees-graphs-bonus-01/solutions/typescript/starter.ts",
      "referencePath": "problems/trees-graphs-bonus-01/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "TreeValueSum",
      "starterPath": "problems/trees-graphs-bonus-01/solutions/go/starter.go",
      "referencePath": "problems/trees-graphs-bonus-01/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "treeValueSum",
      "starterPath": "problems/trees-graphs-bonus-01/solutions/scala/starter.scala",
      "referencePath": "problems/trees-graphs-bonus-01/solutions/scala/reference.scala"
    }
  }
}
