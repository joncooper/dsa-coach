{
  "id": "trees-graphs-bonus-13",
  "kind": "problem",
  "title": "Shortest Path Through A Grid",
  "difficulty": "medium",
  "concepts": [
    "trees-graphs",
    "BFS",
    "shortest path"
  ],
  "prompt": "You are given a grid of 0s (open) and 1s (blocked). Starting at the top-left cell, you may step up, down, left, or right onto open cells only. Return the fewest steps needed to reach the bottom-right cell, or -1 if it cannot be reached.",
  "signature": {
    "name": "shortestGridPath",
    "inputs": [
      {
        "name": "grid",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "path around wall",
      "args": [
        [
          [
            0,
            0,
            0
          ],
          [
            1,
            1,
            0
          ],
          [
            0,
            0,
            0
          ]
        ]
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "fully blocked",
      "args": [
        [
          [
            0,
            1
          ],
          [
            1,
            0
          ]
        ]
      ],
      "expected": -1,
      "visibility": "visible"
    },
    {
      "name": "single open cell",
      "args": [
        [
          [
            0
          ]
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "start blocked",
      "args": [
        [
          [
            1,
            0
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": -1,
      "visibility": "hidden"
    },
    {
      "name": "goal blocked",
      "args": [
        [
          [
            0,
            0
          ],
          [
            0,
            1
          ]
        ]
      ],
      "expected": -1,
      "visibility": "hidden"
    },
    {
      "name": "straight corridor",
      "args": [
        [
          [
            0,
            0,
            0,
            0
          ]
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "open square",
      "args": [
        [
          [
            0,
            0
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "shortest_grid_path",
      "starterPath": "problems/trees-graphs-bonus-13/solutions/python/starter.py",
      "referencePath": "problems/trees-graphs-bonus-13/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "shortestGridPath",
      "starterPath": "problems/trees-graphs-bonus-13/solutions/typescript/starter.ts",
      "referencePath": "problems/trees-graphs-bonus-13/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "ShortestGridPath",
      "starterPath": "problems/trees-graphs-bonus-13/solutions/go/starter.go",
      "referencePath": "problems/trees-graphs-bonus-13/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "shortestGridPath",
      "starterPath": "problems/trees-graphs-bonus-13/solutions/scala/starter.scala",
      "referencePath": "problems/trees-graphs-bonus-13/solutions/scala/reference.scala"
    }
  }
}
