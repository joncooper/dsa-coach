          "starterPath": "problems/tek-rate-limiter/parts/part-2-token-bucket/solutions/python/starter.py",
          "referencePath": "problems/tek-rate-limiter/parts/part-2-token-bucket/solutions/python/reference.py"
        },
        "typescript": {
