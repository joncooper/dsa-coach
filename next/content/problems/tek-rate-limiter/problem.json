{
  "id": "tek-rate-limiter",
  "kind": "problem",
  "title": "Per-User Sliding-Window Rate Limiter",
  "difficulty": "medium",
  "concepts": [
    "sliding window",
    "queue per key",
    "stream processing"
  ],
  "prompt": "Suppose you are building a simple API gateway. Requests arrive over time, and you need to decide whether each request should be accepted or rate-limited.\n\nEach event is `[timestamp, user_id]`. The events are already sorted by timestamp. Write `rateLimited(events, limit, window)` to return one boolean per request: `true` if it is accepted, `false` if it is rejected.\n\nThe rule is per user. A request is accepted only if that user has fewer than `limit` previously accepted requests in the recent window.\n\nUse accepted requests only when counting. Rejected requests do not consume capacity.\n\nThe recent window is `(timestamp - window, timestamp]`. That means a previous accepted request exactly `window` seconds old has expired and no longer counts, but requests at the current timestamp do count after they are accepted.\n\nDifferent users are independent. Duplicate timestamps are allowed. If there are no events, return an empty list.",
  "signature": {
    "name": "rateLimited",
    "inputs": [
      {
        "name": "events",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "any"
            }
          }
        }
      },
      {
        "name": "limit",
        "type": {
          "type": "number"
        }
      },
      {
        "name": "window",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "boolean"
      }
    }
  },
  "tests": [
    {
      "name": "empty stream",
      "args": [
        [],
        5,
        10
      ],
      "expected": [],
      "visibility": "visible"
    },
    {
      "name": "two accepted then one rejected",
      "args": [
        [
          [
            1,
            "a"
          ],
          [
            2,
            "a"
          ],
          [
            3,
            "a"
          ]
        ],
        2,
        5
      ],
      "expected": [
        true,
        true,
        false
      ],
      "visibility": "visible"
    },
    {
      "name": "different users do not interfere",
      "args": [
        [
          [
            1,
            "a"
          ],
          [
            2,
            "b"
          ]
        ],
        1,
        10
      ],
      "expected": [
        true,
        true
      ],
      "visibility": "visible"
    },
    {
      "name": "edge-of-window allowed",
      "args": [
        [
          [
            0,
            "a"
          ],
          [
            5,
            "a"
          ]
        ],
        1,
        5
      ],
      "expected": [
        true,
        true
      ],
      "visibility": "visible"
    },
    {
      "name": "rejected does not consume budget",
      "args": [
        [
          [
            0,
            "a"
          ],
          [
            1,
            "a"
          ],
          [
            5,
            "a"
          ],
          [
            6,
            "a"
          ]
        ],
        1,
        5
