  "parts": [
    {
      "id": "part-2-token-bucket",
      "title": "Part 2: Token-bucket variant",
      "prompt": "Now imagine the product team wants a burst-friendly limiter instead of a strict sliding-window limiter. Use a token bucket for each user.\n\nEach user's bucket starts full the first time that user appears. The bucket can hold at most `capacity` tokens. Every accepted request spends one token. If a user's bucket has no tokens at the request time, reject that request.\n\nTokens refill over time: one whole token every `refill_period` seconds. Extra tokens above `capacity` are dropped.\n\nWrite the token-bucket version so it returns one boolean per event in input order.\n\nBefore handling a user's request at time `t`, refill that user's bucket using only whole refill periods that have elapsed. If `elapsed // refill_period` tokens are earned, advance that user's refill anchor by that many full periods so leftover partial time carries forward.\n\nUsers are independent, and the input events are sorted by timestamp.",
      "signature": {
        "name": "token_bucket_rate_limited",
        "inputs": [
          {
            "name": "arg0",
            "type": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "any"
                }
              }
            }
          },
          {
            "name": "arg1",
            "type": {
              "type": "number"
            }
          },
          {
            "name": "arg2",
            "type": {
              "type": "number"
            }
          }
        ],
        "output": {
          "type": "array",
          "items": {
            "type": "boolean"
          }
        }
      },
      "tests": [
        {
          "name": "empty stream",
          "args": [
            [],
            5,
            10
          ],
          "expected": [],
          "visibility": "visible"
        },
        {
          "name": "start full and drain",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ]
            ],
            2,
            1
          ],
          "expected": [
            true,
            true,
            false
          ],
          "visibility": "visible"
        },
        {
          "name": "one refill arrives",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ],
              [
                1,
                "a"
              ]
            ],
            2,
            1
          ],
          "expected": [
            true,
            true,
            true
          ],
          "visibility": "visible"
        },
        {
          "name": "different users independent",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                0,
                "b"
              ]
            ],
            1,
            10
          ],
          "expected": [
            true,
            true
          ],
          "visibility": "visible"
        },
        {
          "name": "partial elapsed no refill",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ],
              [
                1,
                "a"
              ],
              [
                2,
                "a"
              ]
            ],
            1,
            2
          ],
          "expected": [
            true,
            false,
            false,
            true
          ],
          "visibility": "hidden"
        },
        {
          "name": "exhaust then slow recovery",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ],
              [
                3,
                "a"
              ],
              [
                3,
                "a"
              ]
            ],
            2,
            2
          ],
          "expected": [
            true,
            true,
            false,
            true,
            false
          ],
          "visibility": "hidden"
        },
        {
          "name": "capacity above refill rate",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                10,
                "a"
              ]
            ],
            5,
            1
          ],
          "expected": [
            true,
            true
          ],
          "visibility": "hidden"
        },
        {
          "name": "burst at same timestamp depletes bucket",
          "args": [
            [
              [
                5,
                "a"
              ],
              [
                5,
                "a"
              ],
              [
                5,
                "a"
              ],
              [
                5,
                "a"
              ]
            ],
            3,
            1
          ],
          "expected": [
            true,
            true,
            true,
            false
          ],
          "visibility": "hidden"
        },
        {
          "name": "refill anchor preserves fractional carry",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                4,
                "a"
              ],
              [
                6,
                "a"
              ],
              [
                7,
                "a"
              ]
            ],
            1,
            3
          ],
          "expected": [
            true,
            true,
            true,
            false
          ],
          "visibility": "hidden"
        },
        {
          "name": "refill never exceeds capacity",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ],
              [
                100,
                "a"
              ],
              [
                100,
                "a"
              ],
              [
                100,
                "a"
              ]
            ],
            2,
            1
          ],
          "expected": [
            true,
            true,
            true,
            true,
            false
          ],
          "visibility": "hidden"
        },
        {
          "name": "two users independent bucket state",
          "args": [
            [
              [
                0,
                "a"
              ],
              [
                0,
                "a"
              ],
              [
                0,
                "b"
              ],
              [
                0,
                "b"
              ],
              [
                0,
                "a"
              ],
              [
                0,
                "b"
              ]
            ],
            2,
            5
          ],
          "expected": [
            true,
            true,
            true,
            true,
            false,
            false
          ],
          "visibility": "hidden"
        },
        {
          "name": "zero capacity rejects everything",
          "expected": [
            false,
            false,
            false
          ],
          "args": [
            [
              [
                1,
                "u"
              ],
              [
                10,
                "u"
              ],
              [
                20,
                "v"
              ]
            ],
            0,
            5
          ],
          "visibility": "hidden"
        },
        {
          "name": "large gap refills only to capacity",
          "expected": [
            true,
            true,
            true,
            true,
            false
          ],
          "args": [
            [
              [
                0,
                "u"
              ],
              [
                1,
                "u"
              ],
              [
                100,
                "u"
              ],
              [
                100,
                "u"
              ],
              [
                100,
                "u"
              ]
            ],
            2,
            10
          ],
          "visibility": "hidden"
        }
      ],
