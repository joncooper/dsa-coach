    {
      "id": "l4-double-pay-periods",
      "title": "Double Pay Periods",
      "prompt": "Extend salary calculation with special pay periods. All earlier operations keep working.\n\n**New operation**\n\n- `[\"SET_DOUBLE_PAY\", startTimestamp, endTimestamp]` — mark the half-open interval `[startTimestamp, endTimestamp)` as double-paid and return `\"true\"`. Return `\"false\"` if `startTimestamp >= endTimestamp`. Double-pay periods may overlap, but overlapping coverage does not stack: covered time is paid at exactly 2x the session's active compensation.\n\n`CALC_SALARY` should include the currently registered double-pay periods when calculating salary over completed sessions.",
      "tests": [
        {
          "name": "l4-simple-double-pay",
          "args": [
            [
              [
                "ADD_WORKER",
                "Ann",
                "engineer",
                "10"
              ],
              [
                "SET_DOUBLE_PAY",
                "5",
                "15"
              ],
              [
                "REGISTER",
                "Ann",
                "0"
              ],
              [
                "REGISTER",
                "Ann",
                "20"
              ],
              [
                "CALC_SALARY",
                "Ann",
                "0",
                "20"
              ],
              [
                "GET",
                "Ann"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "registered",
            "registered",
            "300",
            "20"
          ],
          "visibility": "visible"
        },
        {
          "name": "l4-overlapping-double-pay-does-not-stack",
          "args": [
            [
              [
                "ADD_WORKER",
                "Bob",
                "dev",
                "2"
              ],
              [
                "SET_DOUBLE_PAY",
                "5",
                "15"
              ],
              [
                "SET_DOUBLE_PAY",
                "10",
                "25"
              ],
              [
                "SET_DOUBLE_PAY",
                "30",
                "30"
              ],
              [
                "REGISTER",
                "Bob",
                "0"
              ],
              [
                "REGISTER",
                "Bob",
                "30"
              ],
              [
                "CALC_SALARY",
                "Bob",
                "0",
                "30"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "true",
            "false",
            "registered",
            "registered",
            "100"
          ],
          "visibility": "visible"
        },
