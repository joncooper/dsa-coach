{
  "id": "closest-pair-sum",
  "kind": "problem",
  "title": "Closest Pair Sum",
  "difficulty": "medium",
  "concepts": [
    "opposite pointers",
    "sorted array"
  ],
  "prompt": "Given a sorted array, return the sum of two elements at different indices whose sum is closest to `target`. If there is a tie, return the smaller sum.",
  "signature": {
    "name": "closestPairSum",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "target",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "near target",
      "args": [
        [
          1,
          4,
          6,
          8
        ],
        11
      ],
      "expected": 10,
      "visibility": "visible"
    },
    {
      "name": "exact",
      "args": [
        [
          2,
          3,
          5
        ],
        8
      ],
      "expected": 8,
      "visibility": "visible"
    },
    {
      "name": "tie smaller",
      "args": [
        [
          1,
          2,
          8,
          9
        ],
        10
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "negative",
      "args": [
        [
          -5,
          -2,
          7,
          10
        ],
        3
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "two values",
      "args": [
        [
          2,
          9
        ],
        5
      ],
      "expected": 11,
      "visibility": "hidden"
    },
    {
      "name": "target below all",
      "args": [
        [
          5,
          6,
          7,
          8
        ],
        3
      ],
      "expected": 11,
      "visibility": "hidden"
    },
    {
      "name": "target above all",
      "args": [
        [
          1,
          2,
          3
        ],
        100
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "zeros boundary",
      "args": [
        [
          -3,
          0,
          0,
          4
        ],
        1
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "symmetric tie",
      "args": [
        [
          -4,
          -1,
          1,
          4
        ],
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "closest_pair_sum",
      "starterPath": "problems/closest-pair-sum/solutions/python/starter.py",
      "referencePath": "problems/closest-pair-sum/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "closestPairSum",
      "starterPath": "problems/closest-pair-sum/solutions/typescript/starter.ts",
      "referencePath": "problems/closest-pair-sum/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "ClosestPairSum",
      "starterPath": "problems/closest-pair-sum/solutions/go/starter.go",
      "referencePath": "problems/closest-pair-sum/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "closestPairSum",
      "starterPath": "problems/closest-pair-sum/solutions/scala/starter.scala",
      "referencePath": "problems/closest-pair-sum/solutions/scala/reference.scala"
    }
  }
}
