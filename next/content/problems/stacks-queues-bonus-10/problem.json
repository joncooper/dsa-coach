{
  "id": "stacks-queues-bonus-10",
  "kind": "problem",
  "title": "Sliding Window Maximum",
  "difficulty": "medium",
  "concepts": [
    "stacks-queues",
    "monotonic deque",
    "queue"
  ],
  "prompt": "Given a list of integers and a window size k, return the maximum of every contiguous window of length k as the window slides from left to right.",
  "signature": {
    "name": "slidingWindowMax",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "k",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "mixed values",
      "args": [
        [
          1,
          3,
          -1,
          -3,
          5,
          3,
          6,
          7
        ],
        3
      ],
      "expected": [
        3,
        3,
        5,
        5,
        6,
        7
      ],
      "visibility": "visible"
    },
    {
      "name": "window of one",
      "args": [
        [
          4,
          8,
          2
        ],
        1
      ],
      "expected": [
        4,
        8,
        2
      ],
      "visibility": "visible"
    },
    {
      "name": "single window covers all",
      "args": [
        [
          1,
          2,
          3,
          4,
          5
        ],
        5
      ],
      "expected": [
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          4,
          4,
          4,
          4
        ],
        2
      ],
      "expected": [
        4,
        4,
        4
      ],
      "visibility": "hidden"
    },
    {
      "name": "single element",
      "args": [
        [
          7
        ],
        1
      ],
      "expected": [
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "strictly decreasing",
      "args": [
        [
          9,
          8,
          7,
          6
        ],
        2
      ],
      "expected": [
        9,
        8,
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "all negative",
      "args": [
        [
          -1,
          -3,
          -5
        ],
        2
      ],
      "expected": [
        -1,
        -3
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "sliding_window_max",
      "starterPath": "problems/stacks-queues-bonus-10/solutions/python/starter.py",
      "referencePath": "problems/stacks-queues-bonus-10/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "slidingWindowMax",
      "starterPath": "problems/stacks-queues-bonus-10/solutions/typescript/starter.ts",
      "referencePath": "problems/stacks-queues-bonus-10/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "SlidingWindowMax",
      "starterPath": "problems/stacks-queues-bonus-10/solutions/go/starter.go",
      "referencePath": "problems/stacks-queues-bonus-10/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "slidingWindowMax",
      "starterPath": "problems/stacks-queues-bonus-10/solutions/scala/starter.scala",
      "referencePath": "problems/stacks-queues-bonus-10/solutions/scala/reference.scala"
    }
  }
}
