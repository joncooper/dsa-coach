{
  "id": "arrays-strings-bonus-04",
  "kind": "problem",
  "title": "Count Equilibrium Indices",
  "difficulty": "medium",
  "concepts": [
    "arrays-strings",
    "prefix sums",
    "iteration"
  ],
  "prompt": "An equilibrium index is a position where the sum of all values strictly to its left equals the sum of all values strictly to its right. Return how many equilibrium indices the list has.",
  "signature": {
    "name": "countEquilibriumIndices",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "one equilibrium",
      "args": [
        [
          2,
          3,
          -1,
          8,
          4
        ]
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "centre of three",
      "args": [
        [
          1,
          1,
          1
        ]
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          5
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "all zeros",
      "args": [
        [
          0,
          0,
          0
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -1,
          -1,
          -1,
          0,
          1,
          1
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "none",
      "args": [
        [
          1,
          2,
          3
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_equilibrium_indices",
      "starterPath": "problems/arrays-strings-bonus-04/solutions/python/starter.py",
      "referencePath": "problems/arrays-strings-bonus-04/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countEquilibriumIndices",
      "starterPath": "problems/arrays-strings-bonus-04/solutions/typescript/starter.ts",
      "referencePath": "problems/arrays-strings-bonus-04/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountEquilibriumIndices",
      "starterPath": "problems/arrays-strings-bonus-04/solutions/go/starter.go",
      "referencePath": "problems/arrays-strings-bonus-04/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countEquilibriumIndices",
      "starterPath": "problems/arrays-strings-bonus-04/solutions/scala/starter.scala",
      "referencePath": "problems/arrays-strings-bonus-04/solutions/scala/reference.scala"
    }
  }
}
