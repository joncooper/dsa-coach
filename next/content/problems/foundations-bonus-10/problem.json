{
  "id": "foundations-bonus-10",
  "kind": "problem",
  "title": "Nth Fibonacci Number",
  "difficulty": "easy",
  "concepts": [
    "foundations",
    "iteration",
    "running state"
  ],
  "prompt": "Return the n-th Fibonacci number, where Fibonacci 0 is 0, Fibonacci 1 is 1, and each later number is the sum of the previous two.",
  "signature": {
    "name": "nthFibonacci",
    "inputs": [
      {
        "name": "n",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "seventh",
      "args": [
        7
      ],
      "expected": 13,
      "visibility": "visible"
    },
    {
      "name": "base one",
      "args": [
        1
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "base zero",
      "args": [
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "second",
      "args": [
        2
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "third",
      "args": [
        3
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "tenth",
      "args": [
        10
      ],
      "expected": 55,
      "visibility": "hidden"
    },
    {
      "name": "twelfth",
      "args": [
        12
      ],
      "expected": 144,
      "visibility": "hidden"
    }
  ],
