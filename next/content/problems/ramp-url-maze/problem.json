      "name": "branch with one dead end",
      "args": [
        "http://start",
        2
      ],
      "fixture": {
        "http://start": {
          "status": 200,
          "body": {
            "urls": [
              "http://a",
              "http://b"
            ],
            "meta": 1
          }
        },
        "http://a": {
          "status": 200,
          "body": {
            "message": "nothing here"
          }
        },
        "http://b": {
          "status": 200,
          "body": "congrats"
        }
      },
      "expected": "http://b",
      "visibility": "visible"
    },
