{
  "id": "trees-graphs-bonus-12",
  "kind": "problem",
  "title": "Detect Cycle In Directed Graph",
  "difficulty": "medium",
  "concepts": [
    "trees-graphs",
    "DFS",
    "cycle detection"
  ],
  "prompt": "You are given a directed graph as an adjacency map from each node name to a list of node names it points to. Return `true` if the graph contains a directed cycle, and `false` otherwise.",
  "signature": {
    "name": "hasCycle",
    "inputs": [
      {
        "name": "graph",
        "type": {
          "type": "object"
        }
      }
    ],
    "output": {
      "type": "boolean"
    }
  },
  "tests": [
    {
      "name": "three node cycle",
      "args": [
        {
          "a": [
            "b"
          ],
          "b": [
            "c"
          ],
          "c": [
            "a"
          ]
        }
      ],
      "expected": true,
      "visibility": "visible"
    },
    {
      "name": "acyclic chain",
      "args": [
        {
          "a": [
            "b"
          ],
          "b": [
            "c"
          ],
          "c": []
        }
      ],
      "expected": false,
      "visibility": "visible"
    },
    {
      "name": "empty graph",
      "args": [
        {}
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "self loop",
      "args": [
        {
          "a": [
            "a"
          ]
        }
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "acyclic diamond",
      "args": [
        {
          "a": [
            "b",
            "c"
          ],
          "b": [
            "d"
          ],
          "c": [
            "d"
          ],
          "d": []
        }
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "cycle in second component",
      "args": [
        {
          "a": [
            "b"
          ],
          "b": [],
          "c": [
            "d"
          ],
          "d": [
            "c"
          ]
        }
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "long acyclic path",
      "args": [
        {
          "a": [
            "b"
          ],
          "b": [
            "c"
          ],
          "c": [
            "d"
          ],
          "d": [
            "e"
          ],
          "e": []
        }
      ],
      "expected": false,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "has_cycle",
      "starterPath": "problems/trees-graphs-bonus-12/solutions/python/starter.py",
      "referencePath": "problems/trees-graphs-bonus-12/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "hasCycle",
      "starterPath": "problems/trees-graphs-bonus-12/solutions/typescript/starter.ts",
      "referencePath": "problems/trees-graphs-bonus-12/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "HasCycle",
      "starterPath": "problems/trees-graphs-bonus-12/solutions/go/starter.go",
      "referencePath": "problems/trees-graphs-bonus-12/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "hasCycle",
      "starterPath": "problems/trees-graphs-bonus-12/solutions/scala/starter.scala",
      "referencePath": "problems/trees-graphs-bonus-12/solutions/scala/reference.scala"
    }
  }
}
