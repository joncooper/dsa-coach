{
  "id": "binary-search-bonus-04",
  "kind": "problem",
  "title": "Find Peak Element",
  "difficulty": "medium",
  "concepts": [
    "binary-search",
    "peak finding"
  ],
  "prompt": "A peak is an element strictly greater than both of its neighbours; positions just past either end count as negative infinity. Given a list where no two adjacent values are equal, return the index of any peak.",
  "signature": {
    "name": "findPeakElement",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "peak on the right",
      "args": [
        [
          1,
          2,
          3,
          1
        ]
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "peak among two humps",
      "args": [
        [
          1,
          2,
          1,
          3,
          5,
          6,
          4
        ]
      ],
      "expected": 5,
      "visibility": "visible"
    },
    {
      "name": "single",
      "args": [
        [
          9
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "two ascending",
      "args": [
        [
          1,
          2
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "two descending",
      "args": [
        [
          2,
          1
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "strictly increasing",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "strictly decreasing",
      "args": [
        [
          4,
          3,
          2,
          1
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "peak in middle",
      "args": [
        [
          1,
          5,
          2
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -5,
          -2,
          -3
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "find_peak_element",
      "starterPath": "problems/binary-search-bonus-04/solutions/python/starter.py",
      "referencePath": "problems/binary-search-bonus-04/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "findPeakElement",
      "starterPath": "problems/binary-search-bonus-04/solutions/typescript/starter.ts",
      "referencePath": "problems/binary-search-bonus-04/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "FindPeakElement",
      "starterPath": "problems/binary-search-bonus-04/solutions/go/starter.go",
      "referencePath": "problems/binary-search-bonus-04/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "findPeakElement",
      "starterPath": "problems/binary-search-bonus-04/solutions/scala/starter.scala",
      "referencePath": "problems/binary-search-bonus-04/solutions/scala/reference.scala"
    }
  }
}
