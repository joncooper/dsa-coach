              ],
              [
                "CANCEL_PAYMENT",
                "5",
                "a",
                "payment1"
              ],
              [
                "DEPOSIT",
                "20",
                "a",
                "0"
              ]
            ]
          ],
          "expected": [
            "true",
            "100",
            "payment1",
            "true",
            "100"
          ],
          "visibility": "visible"
        },
        {
          "name": "l3-cancel-after-exec-fails",
          "args": [
            [
              [
