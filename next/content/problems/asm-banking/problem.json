                "a",
                "20"
              ],
              [
                "WITHDRAW",
                "6",
                "b",
                "20"
              ],
              [
                "TOP_SPENDERS",
                "7",
                "2"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "100",
            "100",
            "80",
            "80",
            "a(20),b(20)"
          ],
          "visibility": "visible"
        },
        {
