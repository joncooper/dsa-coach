{
  "id": "trees-graphs-bonus-06",
  "kind": "problem",
  "title": "Count Leaf Nodes",
  "difficulty": "easy",
  "concepts": [
    "trees-graphs",
    "tree recursion",
    "DFS"
  ],
  "prompt": "The input `values` encodes a binary tree in level order (breadth-first): `values[0]` is the root, then each following pair gives the left and right child of the next non-null node, and `null` means that child is missing.\n\nReturn the number of leaf nodes: nodes that have no left child and no right child.",
  "signature": {
    "name": "countLeaves",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number",
            "nullable": true
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three leaves",
      "args": [
        [
          1,
          2,
          3,
          4,
          5,
          null,
          6
        ]
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "single node",
      "args": [
        [
          9
        ]
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "empty tree",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "left chain one leaf",
      "args": [
        [
          1,
          2,
          null,
          3
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "full tree",
      "args": [
        [
          1,
          2,
          3,
          4,
          5,
          6,
          7
        ]
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "one child not leaf",
      "args": [
        [
          1,
          2,
          3,
          null,
          null,
          4
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "two leaves",
      "args": [
        [
          1,
          2,
          3
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_leaves",
      "starterPath": "problems/trees-graphs-bonus-06/solutions/python/starter.py",
      "referencePath": "problems/trees-graphs-bonus-06/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countLeaves",
      "starterPath": "problems/trees-graphs-bonus-06/solutions/typescript/starter.ts",
      "referencePath": "problems/trees-graphs-bonus-06/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountLeaves",
      "starterPath": "problems/trees-graphs-bonus-06/solutions/go/starter.go",
      "referencePath": "problems/trees-graphs-bonus-06/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countLeaves",
      "starterPath": "problems/trees-graphs-bonus-06/solutions/scala/starter.scala",
      "referencePath": "problems/trees-graphs-bonus-06/solutions/scala/reference.scala"
    }
  }
}
