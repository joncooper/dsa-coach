{
  "id": "linked-lists-bonus-07",
  "kind": "problem",
  "title": "Is List Sorted Ascending",
  "difficulty": "easy",
  "concepts": [
    "linked-lists",
    "traversal",
    "pairwise comparison"
  ],
  "prompt": "The input `values` serializes a singly linked list in head-to-tail order. The starter code builds a linked-list `head` from that array. Return `true` if its values are in non-decreasing order (equal neighbours are allowed), otherwise return `false`.",
  "signature": {
    "name": "isListSorted",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "boolean"
    }
  },
  "tests": [
    {
      "name": "sorted with duplicates",
      "args": [
        [
          1,
          2,
          2,
          5
        ]
      ],
      "expected": true,
      "visibility": "visible"
    },
    {
      "name": "out of order",
      "args": [
        [
          1,
          3,
          2
        ]
      ],
      "expected": false,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          7
        ]
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "two ascending",
      "args": [
        [
          1,
          2
        ]
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "two descending",
      "args": [
        [
          2,
          1
        ]
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          5,
          5,
          5
        ]
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "drop at end",
      "args": [
        [
          1,
          2,
          3,
          0
        ]
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "negatives sorted",
      "args": [
        [
          -4,
          -1,
          0,
          3
        ]
      ],
      "expected": true,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "is_list_sorted",
      "starterPath": "problems/linked-lists-bonus-07/solutions/python/starter.py",
      "referencePath": "problems/linked-lists-bonus-07/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "isListSorted",
      "starterPath": "problems/linked-lists-bonus-07/solutions/typescript/starter.ts",
      "referencePath": "problems/linked-lists-bonus-07/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "IsListSorted",
      "starterPath": "problems/linked-lists-bonus-07/solutions/go/starter.go",
      "referencePath": "problems/linked-lists-bonus-07/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "isListSorted",
      "starterPath": "problems/linked-lists-bonus-07/solutions/scala/starter.scala",
      "referencePath": "problems/linked-lists-bonus-07/solutions/scala/reference.scala"
    }
  }
}
