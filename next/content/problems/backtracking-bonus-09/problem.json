{
  "id": "backtracking-bonus-09",
  "kind": "problem",
  "title": "Count Latin Square Completions",
  "difficulty": "hard",
  "concepts": [
    "backtracking",
    "constraints",
    "grid search"
  ],
  "prompt": "An n-by-n grid holds values 1..n, with 0 marking a blank cell. Return how many ways the blanks can be filled so that every row and every column contains each value 1..n exactly once. If the grid is empty or its pre-filled values already break the rule, return 0.",
  "signature": {
    "name": "countLatinCompletions",
    "inputs": [
      {
        "name": "grid",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "blank two by two",
      "args": [
        [
          [
            0,
            0
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "forced by one clue",
      "args": [
        [
          [
            1,
            0
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "blank three by three",
      "args": [
        [
          [
            0,
            0,
            0
          ],
          [
            0,
            0,
            0
          ],
          [
            0,
            0,
            0
          ]
        ]
      ],
      "expected": 12,
      "visibility": "hidden"
    },
    {
      "name": "already complete",
      "args": [
        [
          [
            1,
            2
          ],
          [
            2,
            1
          ]
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "invalid clue row",
      "args": [
        [
          [
            1,
            1
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single blank cell",
      "args": [
        [
          [
            0
          ]
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "empty grid",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_latin_completions",
      "starterPath": "problems/backtracking-bonus-09/solutions/python/starter.py",
      "referencePath": "problems/backtracking-bonus-09/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countLatinCompletions",
      "starterPath": "problems/backtracking-bonus-09/solutions/typescript/starter.ts",
      "referencePath": "problems/backtracking-bonus-09/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountLatinCompletions",
      "starterPath": "problems/backtracking-bonus-09/solutions/go/starter.go",
      "referencePath": "problems/backtracking-bonus-09/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countLatinCompletions",
      "starterPath": "problems/backtracking-bonus-09/solutions/scala/starter.scala",
      "referencePath": "problems/backtracking-bonus-09/solutions/scala/reference.scala"
    }
  }
}
