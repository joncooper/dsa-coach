      "referencePath": "problems/stacks-queues-bonus-08/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "AsteroidCollision",
      "starterPath": "problems/stacks-queues-bonus-08/solutions/go/starter.go",
      "referencePath": "problems/stacks-queues-bonus-08/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "asteroidCollision",
      "starterPath": "problems/stacks-queues-bonus-08/solutions/scala/starter.scala",
      "referencePath": "problems/stacks-queues-bonus-08/solutions/scala/reference.scala"
    }
  }
}
