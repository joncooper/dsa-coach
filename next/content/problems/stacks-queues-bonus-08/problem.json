{
  "id": "stacks-queues-bonus-08",
  "kind": "problem",
  "title": "Asteroid Collision",
  "difficulty": "medium",
  "concepts": [
    "stacks-queues",
    "stack",
    "simulation"
  ],
  "prompt": "A row of asteroids moves along a line; each value's magnitude is its size and its sign is its direction (positive moves right, negative moves left). When a right-mover meets a left-mover they collide: the smaller one is destroyed, or both are destroyed if equal. Asteroids moving the same way never collide. Return the row after all collisions settle.",
  "signature": {
    "name": "asteroidCollision",
    "inputs": [
      {
        "name": "asteroids",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "small one destroyed",
      "args": [
        [
          5,
          10,
          -5
        ]
      ],
      "expected": [
        5,
        10
      ],
      "visibility": "visible"
    },
    {
      "name": "equal pair destroyed",
      "args": [
        [
          8,
          -8
        ]
      ],
      "expected": [],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          -1
        ]
      ],
      "expected": [
        -1
      ],
      "visibility": "hidden"
    },
    {
      "name": "no collisions",
      "args": [
        [
          -2,
          -1,
          1,
          2
        ]
      ],
      "expected": [
        -2,
        -1,
        1,
        2
      ],
      "visibility": "hidden"
    },
    {
      "name": "punch through",
      "args": [
        [
          10,
          2,
          -5
        ]
      ],
      "expected": [
        10
      ],
      "visibility": "hidden"
    },
    {
      "name": "left-mover survives chain",
      "args": [
        [
          1,
          -2,
          -2,
          -2
        ]
      ],
      "expected": [
        -2,
        -2,
        -2
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "asteroid_collision",
      "starterPath": "problems/stacks-queues-bonus-08/solutions/python/starter.py",
      "referencePath": "problems/stacks-queues-bonus-08/solutions/python/reference.py"
    },
    "typescript": {
