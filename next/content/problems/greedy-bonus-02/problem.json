{
  "id": "greedy-bonus-02",
  "kind": "problem",
  "title": "Maximum Value On The Truck",
  "difficulty": "easy",
  "concepts": [
    "greedy",
    "sorting",
    "knapsack"
  ],
  "prompt": "Each box is a pair `[units, value_per_unit]`: a stack of identical units, each worth the given value. A truck holds at most `capacity` units total. You may take any number of units from a box — none, some, or all of them. Return the greatest total value the truck can carry.",
  "signature": {
    "name": "maxTruckValue",
    "inputs": [
      {
        "name": "boxes",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      },
      {
        "name": "capacity",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "partial top box",
      "args": [
        [
          [
            3,
            8
          ],
          [
            5,
            4
          ],
          [
            2,
            5
          ]
        ],
        6
      ],
      "expected": 38,
      "visibility": "visible"
    },
    {
      "name": "capacity covers all",
      "args": [
        [
          [
            1,
            2
          ],
          [
            2,
            3
          ]
        ],
        10
      ],
      "expected": 8,
      "visibility": "visible"
    },
    {
      "name": "zero capacity",
      "args": [
        [
          [
            4,
            9
          ]
        ],
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "no boxes",
      "args": [
        [],
        5
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single box partial",
      "args": [
        [
          [
            10,
            7
          ]
        ],
        3
      ],
      "expected": 21,
      "visibility": "hidden"
    },
    {
      "name": "tie on unit value",
      "args": [
        [
          [
            2,
            5
          ],
          [
            2,
            5
          ]
        ],
        3
      ],
      "expected": 15,
      "visibility": "hidden"
    },
    {
      "name": "zero value box ignored first",
      "args": [
        [
          [
            5,
            0
          ],
          [
            2,
            6
          ]
        ],
        4
      ],
      "expected": 12,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "max_truck_value",
      "starterPath": "problems/greedy-bonus-02/solutions/python/starter.py",
      "referencePath": "problems/greedy-bonus-02/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "maxTruckValue",
      "starterPath": "problems/greedy-bonus-02/solutions/typescript/starter.ts",
      "referencePath": "problems/greedy-bonus-02/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MaxTruckValue",
      "starterPath": "problems/greedy-bonus-02/solutions/go/starter.go",
      "referencePath": "problems/greedy-bonus-02/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "maxTruckValue",
      "starterPath": "problems/greedy-bonus-02/solutions/scala/starter.scala",
      "referencePath": "problems/greedy-bonus-02/solutions/scala/reference.scala"
    }
  }
}
