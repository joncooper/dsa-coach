{
  "id": "backtracking-bonus-05",
  "kind": "problem",
  "title": "Count Simple Grid Paths",
  "difficulty": "easy",
  "concepts": [
    "backtracking",
    "grid search",
    "visited set"
  ],
  "prompt": "Given a grid of 0s (open) and 1s (blocked), count the simple paths from the top-left cell to the bottom-right cell. A path may step up, down, left, or right onto open cells and may not visit any cell twice.",
  "signature": {
    "name": "countGridPaths",
    "inputs": [
      {
        "name": "grid",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "open three by three",
      "args": [
        [
          [
            0,
            0,
            0
          ],
          [
            0,
            0,
            0
          ],
          [
            0,
            0,
            0
          ]
        ]
      ],
      "expected": 12,
      "visibility": "visible"
    },
    {
      "name": "one obstacle",
      "args": [
        [
          [
            0,
            1
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "single open cell",
      "args": [
        [
          [
            0
          ]
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "destination unreachable",
      "args": [
        [
          [
            0,
            1
          ],
          [
            1,
            0
          ]
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "start blocked",
      "args": [
        [
          [
            1,
            0
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "empty grid",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "corner detour",
      "args": [
        [
          [
            0,
            0
          ],
          [
            1,
            0
          ]
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_grid_paths",
      "starterPath": "problems/backtracking-bonus-05/solutions/python/starter.py",
      "referencePath": "problems/backtracking-bonus-05/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countGridPaths",
      "starterPath": "problems/backtracking-bonus-05/solutions/typescript/starter.ts",
      "referencePath": "problems/backtracking-bonus-05/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountGridPaths",
      "starterPath": "problems/backtracking-bonus-05/solutions/go/starter.go",
      "referencePath": "problems/backtracking-bonus-05/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countGridPaths",
      "starterPath": "problems/backtracking-bonus-05/solutions/scala/starter.scala",
      "referencePath": "problems/backtracking-bonus-05/solutions/scala/reference.scala"
    }
  }
}
