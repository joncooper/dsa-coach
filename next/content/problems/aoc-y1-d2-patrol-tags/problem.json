      "referencePath": "problems/aoc-y1-d2-patrol-tags/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "count_valid_tags",
      "starterPath": "problems/aoc-y1-d2-patrol-tags/solutions/scala/starter.scala",
      "referencePath": "problems/aoc-y1-d2-patrol-tags/solutions/scala/reference.scala"
    }
  }
}
