{
  "id": "dynamic-programming-bonus-04",
  "kind": "problem",
  "title": "Minimum Path Sum In Grid",
  "difficulty": "medium",
  "concepts": [
    "dynamic-programming",
    "grid",
    "optimization"
  ],
  "prompt": "Given a grid of non-negative integers, you start at the top-left cell and may move only right or down. Return the smallest possible sum of the values on a path to the bottom-right cell.",
  "signature": {
    "name": "minPathSum",
    "inputs": [
      {
        "name": "grid",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three by three",
      "args": [
        [
          [
            1,
            3,
            1
          ],
          [
            1,
            5,
            1
          ],
          [
            4,
            2,
            1
          ]
        ]
      ],
      "expected": 7,
      "visibility": "visible"
    },
    {
      "name": "two rows",
      "args": [
        [
          [
            1,
            2,
            3
          ],
          [
            4,
            5,
            6
          ]
        ]
      ],
      "expected": 12,
      "visibility": "visible"
    },
    {
      "name": "empty grid",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "empty row",
      "args": [
        [
          []
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single cell",
      "args": [
        [
          [
            5
          ]
        ]
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "single row",
      "args": [
        [
          [
            1,
            2,
            3,
            4
          ]
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "single column",
      "args": [
        [
          [
            1
          ],
          [
            2
          ],
          [
            3
          ]
        ]
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "all zeros",
      "args": [
        [
          [
            0,
            0
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "min_path_sum",
      "starterPath": "problems/dynamic-programming-bonus-04/solutions/python/starter.py",
      "referencePath": "problems/dynamic-programming-bonus-04/solutions/python/reference.py"
    },
    "typescript": {
