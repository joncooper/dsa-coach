{
  "id": "tree-level-sums",
  "kind": "problem",
  "title": "Tree Level Sums",
  "difficulty": "medium",
  "concepts": [
    "tree BFS",
    "queue"
  ],
  "prompt": "The input `values` encodes a binary tree in level order (breadth-first): `values[0]` is the root, then each following pair gives the left and right child of the next non-null node, and `null` means that child is missing.\n\nReturn a list where each value is the sum of all tree node values at that depth, from root level downward.",
  "signature": {
    "name": "treeLevelSums",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number",
            "nullable": true
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "three levels",
      "args": [
        [
          1,
          2,
          3,
          4,
          null,
          null,
          5
        ]
      ],
      "expected": [
        1,
        5,
        9
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "visible"
    },
    {
      "name": "single",
      "args": [
        [
          7
        ]
      ],
      "expected": [
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "negative",
      "args": [
        [
          1,
          -2,
          3
        ]
      ],
      "expected": [
        1,
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "only-left",
      "args": [
        [
          1,
          2,
          null,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "only-right",
      "args": [
        [
          1,
          null,
          2,
          null,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "balanced-3-levels",
      "args": [
        [
          1,
          2,
          3,
          4,
          5,
          6,
          7
        ]
      ],
      "expected": [
        1,
        5,
        22
      ],
      "visibility": "hidden"
    },
    {
      "name": "zeros-and-negatives",
      "args": [
        [
          0,
          -1,
          -2,
          3,
          4
        ]
      ],
      "expected": [
        0,
        -3,
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "lopsided",
      "args": [
        [
          5,
          4,
          8,
          null,
          null,
          6,
          7
        ]
      ],
      "expected": [
        5,
        12,
        13
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "tree_level_sums",
      "starterPath": "problems/tree-level-sums/solutions/python/starter.py",
      "referencePath": "problems/tree-level-sums/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "treeLevelSums",
      "starterPath": "problems/tree-level-sums/solutions/typescript/starter.ts",
      "referencePath": "problems/tree-level-sums/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "TreeLevelSums",
      "starterPath": "problems/tree-level-sums/solutions/go/starter.go",
      "referencePath": "problems/tree-level-sums/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "treeLevelSums",
      "starterPath": "problems/tree-level-sums/solutions/scala/starter.scala",
      "referencePath": "problems/tree-level-sums/solutions/scala/reference.scala"
    }
  }
}
