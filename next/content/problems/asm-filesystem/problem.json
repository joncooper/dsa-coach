{
  "id": "asm-filesystem",
  "kind": "problem",
  "title": "Progressive Filesystem",
  "difficulty": "medium",
  "concepts": [
    "simulation",
    "stateful design",
    "hash map",
    "sorting"
  ],
  "prompt": "Implement an in-memory file store driven by a list of operations. `solution(queries)` receives a list of queries; each query is a list of strings `[OP, ...args]`. Return a list with one string result per query, in order.\n\n**Level 1 operations**\n\n- `[\"ADD_FILE\", name, size]` — add a new file. Return `\"true\"` if added, or `\"false\"` if a file with that name already exists (no change in that case). `size` is a non-negative integer given as a string.\n- `[\"GET_FILE_SIZE\", name]` — return the file's size as a string, or `\"\"` if no such file exists.\n- `[\"COPY_FILE\", source, dest]` — copy `source` to `dest` (overwriting `dest` if it already exists). Return `\"true\"`, or `\"false\"` if `source` does not exist.\n\nNames are case-sensitive. This problem has four progressive levels; later levels add operations to this same function, so structure it as a clean per-op dispatcher.",
  "signature": {
    "name": "solution",
    "inputs": [
      {
        "name": "queries",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "tests": [
    {
      "name": "l1-empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "visible"
    },
    {
      "name": "l1-add-then-get",
      "args": [
        [
          [
            "ADD_FILE",
            "a.txt",
            "100"
          ],
          [
            "GET_FILE_SIZE",
            "a.txt"
          ]
        ]
      ],
      "expected": [
        "true",
        "100"
      ],
      "visibility": "visible"
    },
    {
      "name": "l1-duplicate-add",
      "args": [
        [
          [
            "ADD_FILE",
            "a.txt",
            "100"
          ],
          [
            "ADD_FILE",
            "a.txt",
            "200"
          ],
          [
            "GET_FILE_SIZE",
            "a.txt"
          ]
        ]
      ],
      "expected": [
        "true",
        "false",
        "100"
      ],
      "visibility": "visible"
    },
    {
      "name": "l1-copy-then-get",
      "args": [
        [
          [
            "ADD_FILE",
            "a.txt",
            "50"
          ],
          [
            "COPY_FILE",
            "a.txt",
            "b.txt"
          ],
          [
            "GET_FILE_SIZE",
            "b.txt"
          ]
        ]
      ],
      "expected": [
        "true",
        "true",
        "50"
      ],
      "visibility": "visible"
    },
    {
      "name": "l1-copy-missing-src",
      "args": [
        [
          [
            "COPY_FILE",
            "x",
            "y"
          ]
        ]
      ],
      "expected": [
        "false"
      ],
      "visibility": "hidden"
    },
    {
      "name": "l1-get-missing",
      "args": [
        [
          [
            "GET_FILE_SIZE",
            "nope"
          ]
        ]
      ],
      "expected": [
        ""
      ],
      "visibility": "hidden"
    },
    {
      "name": "l1-copy-overwrites-dest",
      "args": [
        [
          [
            "ADD_FILE",
            "a",
            "10"
          ],
          [
            "ADD_FILE",
            "b",
            "99"
          ],
          [
            "COPY_FILE",
            "a",
            "b"
          ],
          [
            "GET_FILE_SIZE",
            "b"
          ]
        ]
      ],
      "expected": [
        "true",
        "true",
        "true",
        "10"
      ],
      "visibility": "hidden"
    },
    {
      "name": "l1-case-sensitive",
      "args": [
        [
          [
            "ADD_FILE",
            "File",
            "1"
          ],
          [
            "GET_FILE_SIZE",
            "file"
          ],
          [
            "GET_FILE_SIZE",
            "File"
          ]
        ]
      ],
      "expected": [
        "true",
        "",
