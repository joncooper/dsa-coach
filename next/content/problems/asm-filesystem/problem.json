      ],
      "expected": [
        "true",
        "0"
      ],
      "visibility": "hidden"
    }
  ],
  "parts": [
    {
      "id": "l2-search",
      "title": "Level 2: Prefix & suffix search",
      "prompt": "Extend your Level 1 file store with search. All Level 1 operations keep working unchanged.\n\n**New operations**\n\n- `[\"FIND_BY_PREFIX\", prefix]` — find every file whose name starts with `prefix`.\n- `[\"FIND_BY_SUFFIX\", suffix]` — find every file whose name ends with `suffix`.\n\nBoth return a single string: the matching files formatted as `name(size)`, joined by commas, **sorted by size descending, breaking ties by name ascending**. Return `\"\"` when nothing matches. An empty `prefix`/`suffix` matches every file.",
      "signature": {
        "name": "solution",
        "inputs": [
          {
            "name": "queries",
            "type": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "output": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "tests": [
        {
          "name": "l2-prefix-by-size-desc",
          "args": [
            [
              [
                "ADD_FILE",
                "data1.txt",
                "30"
              ],
              [
                "ADD_FILE",
                "data2.txt",
                "90"
              ],
              [
                "FIND_BY_PREFIX",
                "data"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "data2.txt(90),data1.txt(30)"
          ],
          "visibility": "visible"
        },
        {
          "name": "l2-prefix-no-match",
          "args": [
            [
              [
                "ADD_FILE",
                "a",
                "1"
              ],
              [
                "FIND_BY_PREFIX",
                "z"
              ]
            ]
          ],
          "expected": [
            "true",
            ""
          ],
          "visibility": "visible"
        },
        {
          "name": "l2-suffix-match",
          "args": [
            [
              [
                "ADD_FILE",
                "a.log",
                "5"
              ],
              [
                "ADD_FILE",
                "b.txt",
                "6"
              ],
              [
                "FIND_BY_SUFFIX",
                ".log"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "a.log(5)"
          ],
          "visibility": "visible"
        },
        {
          "name": "l2-prefix-equals-name",
          "args": [
            [
              [
                "ADD_FILE",
                "report",
                "42"
              ],
              [
                "FIND_BY_PREFIX",
                "report"
              ]
            ]
          ],
          "expected": [
            "true",
            "report(42)"
          ],
          "visibility": "visible"
        },
        {
          "name": "l2-size-tie-lexicographic",
          "args": [
            [
              [
                "ADD_FILE",
                "b",
                "10"
              ],
              [
                "ADD_FILE",
                "a",
                "10"
              ],
              [
                "FIND_BY_PREFIX",
                ""
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "a(10),b(10)"
          ],
          "visibility": "hidden"
        },
        {
          "name": "l2-empty-prefix-all",
          "args": [
            [
              [
                "ADD_FILE",
                "x",
                "5"
              ],
              [
                "ADD_FILE",
                "y",
                "9"
              ],
              [
                "FIND_BY_PREFIX",
                ""
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "y(9),x(5)"
          ],
          "visibility": "hidden"
        },
        {
          "name": "l2-copied-file-searchable",
          "args": [
            [
              [
                "ADD_FILE",
                "src.txt",
                "12"
              ],
              [
                "COPY_FILE",
                "src.txt",
                "dst.txt"
              ],
              [
                "FIND_BY_SUFFIX",
                ".txt"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "dst.txt(12),src.txt(12)"
          ],
          "visibility": "hidden"
        },
        {
          "name": "l2-size-zero-tie",
          "args": [
            [
              [
                "ADD_FILE",
                "f2",
                "0"
              ],
              [
                "ADD_FILE",
                "f1",
                "0"
              ],
              [
                "FIND_BY_PREFIX",
                "f"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "f1(0),f2(0)"
          ],
          "visibility": "hidden"
        },
        {
          "name": "l2-prefix-and-suffix-overlap",
          "args": [
            [
              [
                "ADD_FILE",
                "abc",
                "3"
              ],
              [
                "FIND_BY_PREFIX",
                "ab"
              ],
              [
                "FIND_BY_SUFFIX",
                "bc"
              ]
            ]
          ],
          "expected": [
            "true",
            "abc(3)",
            "abc(3)"
          ],
          "visibility": "hidden"
        }
      ],
