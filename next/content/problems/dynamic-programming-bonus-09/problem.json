{
  "id": "dynamic-programming-bonus-09",
  "kind": "problem",
  "title": "Knapsack Maximum Value",
  "difficulty": "medium",
  "concepts": [
    "dynamic-programming",
    "knapsack",
    "optimization"
  ],
  "prompt": "You have items, each with a weight and a value, and a knapsack with a weight capacity. Return the maximum total value of a subset of items whose total weight does not exceed the capacity. Each item may be taken at most once.",
  "signature": {
    "name": "knapsackMaxValue",
    "inputs": [
      {
        "name": "weights",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "capacity",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "four items",
      "args": [
        [
          1,
          3,
          4,
          5
        ],
        [
          1,
          4,
          5,
          7
        ],
        7
      ],
      "expected": 9,
      "visibility": "visible"
    },
    {
      "name": "three items",
      "args": [
        [
          2,
          3,
          4
        ],
        [
          3,
          4,
          5
        ],
        5
      ],
      "expected": 7,
      "visibility": "visible"
    },
    {
      "name": "no items",
      "args": [
        [],
        [],
        10
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "item too heavy",
      "args": [
        [
          5
        ],
        [
          10
        ],
        4
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "item exactly fits",
      "args": [
        [
          5
        ],
        [
          10
        ],
        5
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "zero capacity",
      "args": [
        [
          1,
          2,
          3
        ],
        [
          6,
          10,
          12
        ],
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "all items overweight",
      "args": [
        [
          4,
          5,
          6
        ],
        [
          1,
          2,
          3
        ],
        3
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "light high value items",
      "args": [
        [
          1,
          1,
          1
        ],
        [
          10,
          20,
          30
        ],
        2
      ],
      "expected": 50,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "knapsack_max_value",
      "starterPath": "problems/dynamic-programming-bonus-09/solutions/python/starter.py",
      "referencePath": "problems/dynamic-programming-bonus-09/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "knapsackMaxValue",
      "starterPath": "problems/dynamic-programming-bonus-09/solutions/typescript/starter.ts",
      "referencePath": "problems/dynamic-programming-bonus-09/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "KnapsackMaxValue",
      "starterPath": "problems/dynamic-programming-bonus-09/solutions/go/starter.go",
      "referencePath": "problems/dynamic-programming-bonus-09/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "knapsackMaxValue",
      "starterPath": "problems/dynamic-programming-bonus-09/solutions/scala/starter.scala",
      "referencePath": "problems/dynamic-programming-bonus-09/solutions/scala/reference.scala"
    }
  }
}
