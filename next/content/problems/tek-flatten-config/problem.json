    },
    "scala": {
      "entrypoint": "flatten_config",
      "starterPath": "problems/tek-flatten-config/solutions/scala/starter.scala",
      "referencePath": "problems/tek-flatten-config/solutions/scala/reference.scala"
    }
  }
}
