{
  "id": "aoc-y1-d1-elevation-pairs",
  "kind": "problem",
  "title": "Day 1: Elevation Pairs",
  "difficulty": "warmup",
  "concepts": [
    "parsing",
    "hash set",
    "pair sum"
  ],
  "prompt": "You receive a survey log as a single multi-line string. The first non-empty line is an integer `target`. Every following non-empty line is one integer elevation reading. Count the number of unordered pairs `(i, j)` with `i < j` such that `readings[i] + readings[j] == target`. Return the count.",
  "signature": {
    "name": "elevation_pairs",
    "inputs": [
      {
        "name": "inputText",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "two pairs sum to 10",
      "args": [
        "10\n3\n7\n5\n5\n2"
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "no pairs",
      "args": [
        "100\n1\n2\n3"
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "empty input",
      "args": [
        ""
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "negative values",
      "args": [
        "0\n-3\n3\n-5\n5"
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "duplicates count distinctly",
      "args": [
        "6\n3\n3\n3"
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "single reading",
      "args": [
        "10\n5"
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "target zero",
      "args": [
        "0\n0\n0\n0"
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "mixed with blanks",
      "args": [
        "8\n1\n\n7\n\n3\n5"
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "target unreachable",
      "args": [
        "1000\n1\n2\n3\n4"
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "four zeros target zero",
      "args": [
        "0\n0\n0\n0\n0"
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "pair value matches half target",
      "args": [
        "10\n5\n5\n5\n5"
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "all negatives sum to negative target",
      "args": [
        "-7\n-3\n-4\n-2\n-5"
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "value pairs with target-itself only when duplicated",
      "args": [
        "6\n3"
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "parts": [
    {
      "id": "part-2-triples",
      "title": "Part 2: Triple sums",
      "prompt": "Same input format. Now count unordered triples `(i, j, k)` with `i < j < k` such that `readings[i] + readings[j] + readings[k] == target`. Return the count.",
      "signature": {
        "name": "elevation_triples",
        "inputs": [
          {
            "name": "inputText",
            "type": {
              "type": "string"
            }
          }
        ],
        "output": {
          "type": "number"
        }
      },
      "tests": [
        {
          "name": "two triples",
          "args": [
            "15\n2\n4\n3\n8\n5"
          ],
          "expected": 2,
          "visibility": "visible"
        },
        {
          "name": "no triples",
          "args": [
            "100\n1\n2\n3\n4"
          ],
          "expected": 0,
          "visibility": "visible"
        },
        {
          "name": "empty",
          "args": [
            ""
          ],
          "expected": 0,
          "visibility": "visible"
        },
        {
          "name": "zero target zero values",
          "args": [
            "0\n0\n0\n0\n0"
          ],
          "expected": 4,
          "visibility": "hidden"
        },
        {
          "name": "negative mix",
          "args": [
            "0\n-2\n-1\n1\n2\n3"
          ],
          "expected": 1,
          "visibility": "hidden"
        },
        {
          "name": "all same",
          "args": [
            "9\n3\n3\n3\n3"
          ],
          "expected": 4,
          "visibility": "hidden"
        },
        {
          "name": "five zeros target zero",
          "args": [
            "0\n0\n0\n0\n0\n0"
          ],
          "expected": 10,
          "visibility": "hidden"
        },
        {
          "name": "target unreachable for triples",
          "args": [
            "1000\n1\n2\n3\n4\n5"
          ],
          "expected": 0,
          "visibility": "hidden"
        },
        {
          "name": "two readings cannot triple",
          "args": [
            "6\n2\n2"
          ],
          "expected": 0,
          "visibility": "hidden"
        },
        {
          "name": "single reading cannot triple",
          "args": [
            "6\n2"
          ],
          "expected": 0,
          "visibility": "hidden"
        }
      ],
      "languages": {
        "python": {
          "entrypoint": "elevation_triples",
          "starterPath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/python/starter.py",
          "referencePath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/python/reference.py"
        },
        "typescript": {
          "entrypoint": "elevation_triples",
          "starterPath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/typescript/starter.ts",
          "referencePath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/typescript/reference.ts"
        },
        "go": {
          "entrypoint": "ElevationTriples",
          "starterPath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/go/starter.go",
          "referencePath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/go/reference.go"
        },
        "scala": {
          "entrypoint": "elevation_triples",
          "starterPath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/scala/starter.scala",
          "referencePath": "problems/aoc-y1-d1-elevation-pairs/parts/part-2-triples/solutions/scala/reference.scala"
        }
      }
    }
  ],
