{
  "id": "arrays-strings-bonus-01",
  "kind": "problem",
  "title": "Reverse Words",
  "difficulty": "warmup",
  "concepts": [
    "arrays-strings",
    "string scan",
    "tokenizing"
  ],
  "prompt": "Given a string of words separated by spaces, return a string with the words in reverse order. Collapse any run of spaces to a single space and drop leading and trailing spaces.",
  "signature": {
    "name": "reverseWords",
    "inputs": [
      {
        "name": "text",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "string"
    }
  },
  "tests": [
    {
      "name": "four words",
      "args": [
        "the sky is blue"
      ],
      "expected": "blue is sky the",
      "visibility": "visible"
    },
    {
      "name": "padded spaces",
      "args": [
        "  hello   world  "
      ],
      "expected": "world hello",
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": "",
      "visibility": "hidden"
    },
    {
      "name": "only spaces",
      "args": [
        "   "
      ],
      "expected": "",
      "visibility": "hidden"
    },
    {
      "name": "single word",
      "args": [
        "single"
      ],
      "expected": "single",
      "visibility": "hidden"
    },
    {
      "name": "five words",
      "args": [
        "a b c d e"
      ],
      "expected": "e d c b a",
      "visibility": "hidden"
    },
    {
      "name": "trailing space",
      "args": [
        "trailing space "
      ],
      "expected": "space trailing",
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "reverse_words",
      "starterPath": "problems/arrays-strings-bonus-01/solutions/python/starter.py",
      "referencePath": "problems/arrays-strings-bonus-01/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "reverseWords",
      "starterPath": "problems/arrays-strings-bonus-01/solutions/typescript/starter.ts",
      "referencePath": "problems/arrays-strings-bonus-01/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "ReverseWords",
      "starterPath": "problems/arrays-strings-bonus-01/solutions/go/starter.go",
      "referencePath": "problems/arrays-strings-bonus-01/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "reverseWords",
      "starterPath": "problems/arrays-strings-bonus-01/solutions/scala/starter.scala",
      "referencePath": "problems/arrays-strings-bonus-01/solutions/scala/reference.scala"
    }
  }
}
