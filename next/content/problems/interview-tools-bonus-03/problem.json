{
  "id": "interview-tools-bonus-03",
  "kind": "problem",
  "title": "Longest Run Of At Most Two Values",
  "difficulty": "medium",
  "concepts": [
    "interview-tools",
    "two-pointers-sliding-window",
    "variable window"
  ],
  "prompt": "Return the length of the longest contiguous subarray that contains at most two distinct values.",
  "signature": {
    "name": "longestTwoValueRun",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three distinct values",
      "args": [
        [
          1,
          2,
          1,
          2,
          3
        ]
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "all the same",
      "args": [
        [
          5,
          5,
          5,
          5
        ]
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          8
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "exactly two",
      "args": [
        [
          1,
          1,
          2,
          2
        ]
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "window at end",
      "args": [
        [
          4,
          5,
          6,
          7,
          7
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "alternating",
      "args": [
        [
          9,
          8,
          9,
          8,
          9
        ]
      ],
      "expected": 5,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "longest_two_value_run",
      "starterPath": "problems/interview-tools-bonus-03/solutions/python/starter.py",
      "referencePath": "problems/interview-tools-bonus-03/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "longestTwoValueRun",
      "starterPath": "problems/interview-tools-bonus-03/solutions/typescript/starter.ts",
      "referencePath": "problems/interview-tools-bonus-03/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "LongestTwoValueRun",
      "starterPath": "problems/interview-tools-bonus-03/solutions/go/starter.go",
      "referencePath": "problems/interview-tools-bonus-03/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "longestTwoValueRun",
      "starterPath": "problems/interview-tools-bonus-03/solutions/scala/starter.scala",
      "referencePath": "problems/interview-tools-bonus-03/solutions/scala/reference.scala"
    }
  }
}
