{
  "id": "hashing-bonus-11",
  "kind": "problem",
  "title": "Distinct Pair Sums",
  "difficulty": "medium",
  "concepts": [
    "hashing",
    "set membership",
    "pair enumeration"
  ],
  "prompt": "Consider every unordered pair of values at two different indices. Return how many distinct sums those pairs produce.",
  "signature": {
    "name": "countDistinctPairSums",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three distinct sums",
      "args": [
        [
          1,
          2,
          3
        ]
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "all equal values",
      "args": [
        [
          1,
          1,
          1
        ]
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          5
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "one pair",
      "args": [
        [
          2,
          4
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "four values",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -1,
          0,
          1
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "all zeros",
      "args": [
        [
          0,
          0,
          0,
          0
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_distinct_pair_sums",
      "starterPath": "problems/hashing-bonus-11/solutions/python/starter.py",
      "referencePath": "problems/hashing-bonus-11/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countDistinctPairSums",
      "starterPath": "problems/hashing-bonus-11/solutions/typescript/starter.ts",
      "referencePath": "problems/hashing-bonus-11/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountDistinctPairSums",
      "starterPath": "problems/hashing-bonus-11/solutions/go/starter.go",
      "referencePath": "problems/hashing-bonus-11/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countDistinctPairSums",
      "starterPath": "problems/hashing-bonus-11/solutions/scala/starter.scala",
      "referencePath": "problems/hashing-bonus-11/solutions/scala/reference.scala"
    }
  }
}
