{
  "id": "sum-positive-readings",
  "kind": "problem",
  "title": "Sum Positive Readings",
  "difficulty": "warmup",
  "concepts": [
    "single pass",
    "filtering"
  ],
  "prompt": "Given a list of integer sensor readings, return the sum of only the positive readings. Zero and negative readings do not contribute.",
  "signature": {
    "name": "sumPositiveReadings",
    "inputs": [
      {
        "name": "readings",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "mixed readings",
      "args": [
        [
          3,
          -2,
          7,
          0,
          -5
        ]
      ],
      "expected": 10,
      "visibility": "visible"
    },
    {
      "name": "no positives",
      "args": [
        [
          -4,
          0,
          -1
        ]
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "all positives",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single positive",
      "args": [
        [
          42
        ]
      ],
      "expected": 42,
      "visibility": "hidden"
    },
    {
      "name": "single negative",
      "args": [
        [
          -7
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "zeros only",
      "args": [
        [
          0,
          0,
          0
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "large mixed",
      "args": [
        [
          10,
          -10,
          20,
          -20,
          30,
          -30,
          40
        ]
      ],
      "expected": 100,
      "visibility": "hidden"
    },
    {
      "name": "boundary one",
      "args": [
        [
          1,
          -1,
          1,
          -1
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "sum_positive_readings",
      "starterPath": "problems/sum-positive-readings/solutions/python/starter.py",
      "referencePath": "problems/sum-positive-readings/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "sumPositiveReadings",
      "starterPath": "problems/sum-positive-readings/solutions/typescript/starter.ts",
      "referencePath": "problems/sum-positive-readings/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "SumPositiveReadings",
      "starterPath": "problems/sum-positive-readings/solutions/go/starter.go",
      "referencePath": "problems/sum-positive-readings/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "sumPositiveReadings",
      "starterPath": "problems/sum-positive-readings/solutions/scala/starter.scala",
      "referencePath": "problems/sum-positive-readings/solutions/scala/reference.scala"
    }
  }
}
