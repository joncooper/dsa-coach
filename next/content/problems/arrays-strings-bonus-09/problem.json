{
  "id": "arrays-strings-bonus-09",
  "kind": "problem",
  "title": "Dedupe Sorted Array",
  "difficulty": "warmup",
  "concepts": [
    "arrays-strings",
    "write pointer",
    "adjacent compare"
  ],
  "prompt": "Given a list of integers already sorted in non-decreasing order, return a new list with consecutive duplicates removed so each value appears once.",
  "signature": {
    "name": "dedupeSorted",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "runs collapse",
      "args": [
        [
          1,
          1,
          2,
          2,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "visible"
    },
    {
      "name": "long run",
      "args": [
        [
          7,
          7,
          7,
          8
        ]
      ],
      "expected": [
        7,
        8
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          5
        ]
      ],
      "expected": [
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          1,
          1,
          1
        ]
      ],
      "expected": [
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "already unique",
      "args": [
        [
          1,
          2,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -2,
          -2,
          -1,
          0,
          0
        ]
      ],
      "expected": [
        -2,
        -1,
        0
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "dedupe_sorted",
      "starterPath": "problems/arrays-strings-bonus-09/solutions/python/starter.py",
      "referencePath": "problems/arrays-strings-bonus-09/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "dedupeSorted",
      "starterPath": "problems/arrays-strings-bonus-09/solutions/typescript/starter.ts",
      "referencePath": "problems/arrays-strings-bonus-09/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "DedupeSorted",
      "starterPath": "problems/arrays-strings-bonus-09/solutions/go/starter.go",
      "referencePath": "problems/arrays-strings-bonus-09/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "dedupeSorted",
      "starterPath": "problems/arrays-strings-bonus-09/solutions/scala/starter.scala",
      "referencePath": "problems/arrays-strings-bonus-09/solutions/scala/reference.scala"
    }
  }
}
