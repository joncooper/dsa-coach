{
  "id": "hashing-bonus-04",
  "kind": "problem",
  "title": "Two Sum Exists",
  "difficulty": "easy",
  "concepts": [
    "hashing",
    "complement set",
    "iteration"
  ],
  "prompt": "Return `true` if some pair of values at two different indices adds up to the target, and `false` otherwise.",
  "signature": {
    "name": "twoSumExists",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "target",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "boolean"
    }
  },
  "tests": [
    {
      "name": "pair found",
      "args": [
        [
          2,
          7,
          11,
          15
        ],
        9
      ],
      "expected": true,
      "visibility": "visible"
    },
    {
      "name": "no pair",
      "args": [
        [
          1,
          2,
          3
        ],
        7
      ],
      "expected": false,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        0
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          5
        ],
        10
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "equal halves",
      "args": [
        [
          3,
          3
        ],
        6
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "two zeros",
      "args": [
        [
          0,
          0
        ],
        0
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "negative partner",
      "args": [
        [
          -3,
          4,
          1
        ],
        1
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "value not reused",
      "args": [
        [
          4
        ],
        8
      ],
      "expected": false,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "two_sum_exists",
      "starterPath": "problems/hashing-bonus-04/solutions/python/starter.py",
      "referencePath": "problems/hashing-bonus-04/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "twoSumExists",
      "starterPath": "problems/hashing-bonus-04/solutions/typescript/starter.ts",
      "referencePath": "problems/hashing-bonus-04/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "TwoSumExists",
      "starterPath": "problems/hashing-bonus-04/solutions/go/starter.go",
      "referencePath": "problems/hashing-bonus-04/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "twoSumExists",
      "starterPath": "problems/hashing-bonus-04/solutions/scala/starter.scala",
      "referencePath": "problems/hashing-bonus-04/solutions/scala/reference.scala"
    }
  }
}
