{
  "id": "interview-tools-bonus-06",
  "kind": "problem",
  "title": "Peak Element Index",
  "difficulty": "medium",
  "concepts": [
    "interview-tools",
    "binary-search",
    "halving search"
  ],
  "prompt": "A peak is an element strictly greater than each of its immediate neighbours; positions off either end of the list count as negative infinity. The list never has two equal adjacent values, so a peak always exists. Return the index of any one peak. Aim for a search that runs in better than linear time.",
  "signature": {
    "name": "peakIndex",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "peak in middle",
      "args": [
        [
          1,
          3,
          2
        ]
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "strictly increasing",
      "args": [
        [
          1,
          2,
          3,
          4,
          5
        ]
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "single element",
      "args": [
        [
          7
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "two ascending",
      "args": [
        [
          1,
          2
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "two descending",
      "args": [
        [
          2,
          1
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "strictly decreasing",
      "args": [
        [
          5,
          4,
          3,
          2,
          1
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "peak then valley then peak",
      "args": [
        [
          1,
          2,
          1,
          3,
          5,
          6,
          4
        ]
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "negative values",
      "args": [
        [
          -9,
          -3,
          -7
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "peak_index",
      "starterPath": "problems/interview-tools-bonus-06/solutions/python/starter.py",
      "referencePath": "problems/interview-tools-bonus-06/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "peakIndex",
      "starterPath": "problems/interview-tools-bonus-06/solutions/typescript/starter.ts",
      "referencePath": "problems/interview-tools-bonus-06/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "PeakIndex",
      "starterPath": "problems/interview-tools-bonus-06/solutions/go/starter.go",
      "referencePath": "problems/interview-tools-bonus-06/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "peakIndex",
      "starterPath": "problems/interview-tools-bonus-06/solutions/scala/starter.scala",
      "referencePath": "problems/interview-tools-bonus-06/solutions/scala/reference.scala"
    }
  }
}
