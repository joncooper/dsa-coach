{
  "id": "heaps-bonus-05",
  "kind": "problem",
  "title": "Top K Frequent Numbers",
  "difficulty": "easy",
  "concepts": [
    "heaps",
    "top k",
    "frequency count"
  ],
  "prompt": "Return the k values that appear most often in the list. Break ties by preferring the smaller value. Return the chosen values sorted in ascending order.",
  "signature": {
    "name": "topKFrequent",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "k",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "two most frequent",
      "args": [
        [
          1,
          1,
          1,
          2,
          2,
          3
        ],
        2
      ],
      "expected": [
        1,
        2
      ],
      "visibility": "visible"
    },
    {
      "name": "single value",
      "args": [
        [
          7
        ],
        1
      ],
      "expected": [
        7
      ],
      "visibility": "visible"
    },
    {
      "name": "tie broken by smaller",
      "args": [
        [
          4,
          4,
          5,
          5,
          6
        ],
        1
      ],
      "expected": [
        4
      ],
      "visibility": "hidden"
    },
    {
      "name": "all distinct take all",
      "args": [
        [
          3,
          1,
          2
        ],
        3
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -1,
          -1,
          -2,
          -2,
          -2,
          0
        ],
        2
      ],
      "expected": [
        -2,
        -1
      ],
      "visibility": "hidden"
    },
    {
      "name": "k equals one clear winner",
      "args": [
        [
          9,
          9,
          9,
          1,
          2
        ],
        1
      ],
      "expected": [
        9
      ],
      "visibility": "hidden"
    },
    {
      "name": "all equal frequency pick smallest",
      "args": [
        [
          5,
          6,
          7,
          8
        ],
        2
      ],
      "expected": [
        5,
        6
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "top_k_frequent",
      "starterPath": "problems/heaps-bonus-05/solutions/python/starter.py",
      "referencePath": "problems/heaps-bonus-05/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "topKFrequent",
      "starterPath": "problems/heaps-bonus-05/solutions/typescript/starter.ts",
      "referencePath": "problems/heaps-bonus-05/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "TopKFrequent",
      "starterPath": "problems/heaps-bonus-05/solutions/go/starter.go",
      "referencePath": "problems/heaps-bonus-05/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "topKFrequent",
      "starterPath": "problems/heaps-bonus-05/solutions/scala/starter.scala",
      "referencePath": "problems/heaps-bonus-05/solutions/scala/reference.scala"
    }
  }
}
