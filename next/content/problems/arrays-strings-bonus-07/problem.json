{
  "id": "arrays-strings-bonus-07",
  "kind": "problem",
  "title": "First Unique Character Index",
  "difficulty": "easy",
  "concepts": [
    "arrays-strings",
    "string scan",
    "two pass"
  ],
  "prompt": "Return the index of the first character in the string that appears exactly once. If every character repeats, or the string is empty, return -1.",
  "signature": {
    "name": "firstUniqueIndex",
    "inputs": [
      {
        "name": "text",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "unique at start",
      "args": [
        "leetcode"
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "unique in middle",
      "args": [
        "swiss"
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": -1,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        "x"
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "all repeat",
      "args": [
        "aabb"
      ],
      "expected": -1,
      "visibility": "hidden"
    },
    {
      "name": "every char twice",
      "args": [
        "abcabc"
      ],
      "expected": -1,
      "visibility": "hidden"
    },
    {
      "name": "unique at end",
      "args": [
        "aabbc"
      ],
      "expected": 4,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "first_unique_index",
      "starterPath": "problems/arrays-strings-bonus-07/solutions/python/starter.py",
      "referencePath": "problems/arrays-strings-bonus-07/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "firstUniqueIndex",
      "starterPath": "problems/arrays-strings-bonus-07/solutions/typescript/starter.ts",
      "referencePath": "problems/arrays-strings-bonus-07/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "FirstUniqueIndex",
      "starterPath": "problems/arrays-strings-bonus-07/solutions/go/starter.go",
      "referencePath": "problems/arrays-strings-bonus-07/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "firstUniqueIndex",
      "starterPath": "problems/arrays-strings-bonus-07/solutions/scala/starter.scala",
      "referencePath": "problems/arrays-strings-bonus-07/solutions/scala/reference.scala"
    }
  }
}
