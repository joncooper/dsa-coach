{
  "id": "lib-od-lru-cache",
  "kind": "problem",
  "title": "LRU Cache",
  "difficulty": "medium",
  "concepts": [
    "LRU",
    "OrderedDict",
    "cache"
  ],
  "prompt": "Implement a least-recently-used cache. `lru_cache(capacity, operations)` receives an integer `capacity` and a list of operations. Each operation is either `[\"get\", key]` or `[\"put\", key, value]` (keys and values are strings). `get` looks up the key: if present, it marks the key as most-recently-used and emits the value; if absent, it emits `\"-1\"`. `put` inserts or updates the key (also marking it most-recently-used). Whenever the cache exceeds `capacity` after a `put`, evict the least-recently-used entry. Return only the `get` results, in order.",
  "signature": {
    "name": "lruCache",
    "inputs": [
      {
        "name": "capacity",
        "type": {
          "type": "number"
        }
      },
      {
        "name": "operations",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "tests": [
    {
      "name": "empty operations",
      "args": [
        2,
        []
      ],
      "expected": [],
      "visibility": "visible"
    },
    {
      "name": "single put then get",
      "args": [
        2,
        [
          [
            "put",
            "a",
            "1"
          ],
          [
            "get",
            "a"
          ]
        ]
      ],
      "expected": [
        "1"
      ],
      "visibility": "visible"
    },
    {
      "name": "missing key returns -1",
      "args": [
        2,
        [
          [
            "get",
            "x"
          ]
        ]
      ],
      "expected": [
        "-1"
      ],
      "visibility": "visible"
    },
    {
      "name": "eviction at capacity",
      "args": [
        2,
        [
          [
            "put",
            "a",
            "1"
          ],
          [
            "put",
            "b",
            "2"
          ],
          [
            "get",
            "a"
          ],
          [
            "put",
            "c",
            "3"
          ],
          [
            "get",
            "b"
          ],
          [
            "get",
            "c"
          ]
        ]
      ],
      "expected": [
        "1",
        "-1",
        "3"
      ],
      "visibility": "visible"
    },
    {
      "name": "put overwrites and is now most-recent",
      "args": [
        2,
        [
          [
            "put",
            "a",
            "1"
          ],
          [
            "put",
            "b",
            "2"
          ],
          [
            "put",
            "a",
            "9"
          ],
          [
            "put",
            "c",
            "3"
          ],
          [
            "get",
            "b"
          ],
          [
            "get",
            "a"
          ],
          [
            "get",
            "c"
          ]
        ]
      ],
      "expected": [
        "-1",
        "9",
        "3"
      ],
      "visibility": "hidden"
    },
    {
      "name": "get refreshes recency",
      "args": [
        2,
        [
          [
            "put",
            "a",
            "1"
          ],
          [
            "put",
            "b",
            "2"
          ],
          [
            "get",
            "a"
          ],
          [
            "put",
            "c",
            "3"
          ],
          [
            "get",
            "a"
          ],
          [
            "get",
            "b"
          ]
        ]
      ],
      "expected": [
        "1",
        "1",
        "-1"
      ],
      "visibility": "hidden"
    },
    {
      "name": "capacity one only keeps the latest",
      "args": [
        1,
        [
          [
            "put",
            "a",
            "1"
          ],
          [
            "put",
            "b",
            "2"
          ],
          [
            "put",
            "c",
            "3"
          ],
          [
            "get",
            "a"
          ],
          [
            "get",
            "b"
          ],
          [
            "get",
            "c"
          ]
        ]
      ],
      "expected": [
        "-1",
        "-1",
        "3"
      ],
      "visibility": "hidden"
    },
    {
      "name": "interleaved gets and puts",
      "args": [
        3,
        [
          [
            "put",
            "a",
            "1"
          ],
          [
            "put",
            "b",
            "2"
          ],
          [
            "put",
            "c",
            "3"
          ],
          [
            "get",
            "a"
          ],
          [
            "put",
            "d",
            "4"
          ],
          [
            "get",
            "b"
          ],
          [
            "get",
            "c"
          ],
          [
            "get",
            "d"
          ],
          [
            "get",
            "a"
          ]
        ]
      ],
      "expected": [
        "1",
        "-1",
        "3",
        "4",
        "1"
      ],
      "visibility": "hidden"
    },
    {
      "name": "all gets miss when nothing was put",
      "args": [
        4,
        [
          [
            "get",
            "a"
          ],
          [
            "get",
            "b"
          ],
          [
            "get",
            "c"
          ]
        ]
      ],
      "expected": [
        "-1",
        "-1",
        "-1"
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "lru_cache",
      "starterPath": "problems/lib-od-lru-cache/solutions/python/starter.py",
      "referencePath": "problems/lib-od-lru-cache/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "lruCache",
      "starterPath": "problems/lib-od-lru-cache/solutions/typescript/starter.ts",
      "referencePath": "problems/lib-od-lru-cache/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "LruCache",
      "starterPath": "problems/lib-od-lru-cache/solutions/go/starter.go",
      "referencePath": "problems/lib-od-lru-cache/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "lruCache",
      "starterPath": "problems/lib-od-lru-cache/solutions/scala/starter.scala",
      "referencePath": "problems/lib-od-lru-cache/solutions/scala/reference.scala"
    }
  }
}
