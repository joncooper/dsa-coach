{
  "id": "recent-event-counts",
  "kind": "problem",
  "title": "Recent Event Counts",
  "difficulty": "medium",
  "concepts": [
    "queue",
    "sliding time window"
  ],
  "prompt": "Event timestamps arrive sorted. For each timestamp, return how many events are in the inclusive range `[timestamp - window, timestamp]`.",
  "signature": {
    "name": "recentEventCounts",
    "inputs": [
      {
        "name": "timestamps",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "window",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "small",
      "args": [
        [
          1,
          3,
          8,
          10
        ],
        5
      ],
      "expected": [
        1,
        2,
        2,
        2
      ],
      "visibility": "visible"
    },
    {
      "name": "window zero",
      "args": [
        [
          2,
          2,
          3
        ],
        0
      ],
      "expected": [
        1,
        2,
        1
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        10
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "wide",
      "args": [
        [
          1,
          2,
          3
        ],
        100
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "single event",
      "args": [
        [
          5
        ],
        3
      ],
      "expected": [
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "all same timestamp",
      "args": [
        [
          4,
          4,
          4,
          4
        ],
        2
      ],
      "expected": [
        1,
        2,
        3,
        4
      ],
      "visibility": "hidden"
    },
    {
      "name": "window one",
      "args": [
        [
          1,
          2,
          3,
          5,
          6
        ],
        1
      ],
      "expected": [
        1,
        2,
        2,
        1,
        2
      ],
      "visibility": "hidden"
    },
    {
      "name": "gap larger than window",
      "args": [
        [
          1,
          10,
          20
        ],
        3
      ],
      "expected": [
        1,
        1,
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "large window",
      "args": [
        [
          2,
          4,
          6,
          8,
          10
        ],
        1000
      ],
      "expected": [
        1,
        2,
        3,
        4,
        5
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "recent_event_counts",
      "starterPath": "problems/recent-event-counts/solutions/python/starter.py",
      "referencePath": "problems/recent-event-counts/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "recentEventCounts",
      "starterPath": "problems/recent-event-counts/solutions/typescript/starter.ts",
      "referencePath": "problems/recent-event-counts/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "RecentEventCounts",
      "starterPath": "problems/recent-event-counts/solutions/go/starter.go",
      "referencePath": "problems/recent-event-counts/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "recentEventCounts",
      "starterPath": "problems/recent-event-counts/solutions/scala/starter.scala",
      "referencePath": "problems/recent-event-counts/solutions/scala/reference.scala"
    }
  }
}
