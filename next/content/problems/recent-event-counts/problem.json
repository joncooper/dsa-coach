{
  "id": "recent-event-counts",
  "kind": "problem",
  "title": "Recent Event Counts",
  "difficulty": "medium",
  "concepts": [
    "sliding window",
    "two pointers",
    "queue"
  ],
  "prompt": "Imagine an analytics dashboard that receives events over time. For every event, the dashboard wants to know: how many events have happened recently, ending at this event's timestamp?\n\nYou are given sorted event timestamps and a window size. Write `recentEventCounts(timestamps, window)` so that for each timestamp `t`, it counts how many events seen so far fall inside `[t - window, t]`.\n\nThe current event always counts, because its timestamp is exactly `t`. Earlier events count only if they are not older than `t - window`.\n\nDuplicates are separate events. So if two events have the same timestamp, they both count. If `window` is `0`, only events at exactly the current timestamp count.\n\nReturn one integer per input timestamp, in the same order as the input. If there are no timestamps, return an empty list.",
  "signature": {
    "name": "recentEventCounts",
    "inputs": [
      {
        "name": "timestamps",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "window",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "small",
      "args": [
        [
          1,
          3,
          8,
          10
        ],
        5
      ],
      "expected": [
        1,
        2,
        2,
        2
      ],
      "visibility": "visible"
    },
    {
      "name": "window zero",
      "args": [
        [
          2,
          2,
          3
        ],
        0
      ],
      "expected": [
        1,
        2,
        1
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        10
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "wide",
      "args": [
        [
          1,
          2,
          3
        ],
        100
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "single event",
      "args": [
        [
          5
        ],
        3
      ],
      "expected": [
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "all same timestamp",
      "args": [
        [
          4,
          4,
          4,
          4
        ],
        2
      ],
      "expected": [
        1,
        2,
        3,
        4
      ],
      "visibility": "hidden"
    },
    {
      "name": "window one",
      "args": [
        [
          1,
          2,
          3,
          5,
          6
        ],
        1
      ],
      "expected": [
        1,
        2,
        2,
        1,
        2
      ],
      "visibility": "hidden"
    },
    {
      "name": "gap larger than window",
      "args": [
        [
          1,
          10,
          20
        ],
        3
      ],
      "expected": [
        1,
        1,
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "large window",
      "args": [
        [
          2,
          4,
          6,
          8,
          10
        ],
        1000
      ],
      "expected": [
        1,
        2,
        3,
        4,
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "inclusive left boundary",
      "expected": [
        1,
        2,
        2
      ],
      "args": [
        [
          1,
          6,
          7
        ],
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "duplicates on boundary",
      "expected": [
        1,
        2,
        3,
        4,
        3
      ],
      "args": [
        [
          0,
          0,
          5,
          5,
          6
        ],
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "negative timestamps",
      "expected": [
        1,
        2,
        2
      ],
      "args": [
        [
          -5,
          0,
          5
        ],
        5
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "recent_event_counts",
      "starterPath": "problems/recent-event-counts/solutions/python/starter.py",
      "referencePath": "problems/recent-event-counts/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "recentEventCounts",
      "starterPath": "problems/recent-event-counts/solutions/typescript/starter.ts",
      "referencePath": "problems/recent-event-counts/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "RecentEventCounts",
      "starterPath": "problems/recent-event-counts/solutions/go/starter.go",
      "referencePath": "problems/recent-event-counts/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "recentEventCounts",
      "starterPath": "problems/recent-event-counts/solutions/scala/starter.scala",
      "referencePath": "problems/recent-event-counts/solutions/scala/reference.scala"
    }
  }
}
