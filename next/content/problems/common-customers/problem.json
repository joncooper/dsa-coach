{
  "id": "common-customers",
  "kind": "problem",
  "title": "Common Customers",
  "difficulty": "easy",
  "concepts": [
    "set intersection"
  ],
  "prompt": "Return the number of distinct customer ids that appear in both the morning and evening lists.",
  "signature": {
    "name": "commonCustomers",
    "inputs": [
      {
        "name": "morning",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "evening",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "overlap",
      "args": [
        [
          1,
          2,
          2,
          3
        ],
        [
          3,
          3,
          4,
          1
        ]
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "none",
      "args": [
        [
          1
        ],
        [
          2
        ]
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "duplicates",
      "args": [
        [
          5,
          5,
          5
        ],
        [
          5
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "empty",
      "args": [
        [],
        [
          1,
          2
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "both empty",
      "args": [
        [],
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "identical",
      "args": [
        [
          1,
          2,
          3
        ],
        [
          1,
          2,
          3
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "subset",
      "args": [
        [
          1,
          2
        ],
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "no overlap with dupes",
      "args": [
        [
          1,
          1,
          2,
          2
        ],
        [
          3,
          3,
          4,
          4
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "many duplicates overlap one",
      "args": [
        [
          7,
          7,
          7,
          8,
          9
        ],
        [
          9,
          9,
          10
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "common_customers",
      "starterPath": "problems/common-customers/solutions/python/starter.py",
      "referencePath": "problems/common-customers/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "commonCustomers",
      "starterPath": "problems/common-customers/solutions/typescript/starter.ts",
      "referencePath": "problems/common-customers/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CommonCustomers",
      "starterPath": "problems/common-customers/solutions/go/starter.go",
      "referencePath": "problems/common-customers/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "commonCustomers",
      "starterPath": "problems/common-customers/solutions/scala/starter.scala",
      "referencePath": "problems/common-customers/solutions/scala/reference.scala"
    }
  }
}
