{
  "id": "heaps-bonus-01",
  "kind": "problem",
  "title": "Kth Largest Element",
  "difficulty": "warmup",
  "concepts": [
    "heaps",
    "top k",
    "bounded heap"
  ],
  "prompt": "Return the k-th largest value in the list. The k-th largest is the value that would sit at position k counting down from the maximum, so for k = 1 it is the maximum itself. Duplicates count as ordinary values.",
  "signature": {
    "name": "kthLargest",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "k",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "second largest",
      "args": [
        [
          3,
          2,
          1,
          5,
          6,
          4
        ],
        2
      ],
      "expected": 5,
      "visibility": "visible"
    },
    {
      "name": "fourth largest with dupes",
      "args": [
        [
          3,
          2,
          3,
          1,
          2,
          4,
          5,
          5,
          6
        ],
        4
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "k equals one is max",
      "args": [
        [
          7,
          1,
          9,
          3
        ],
        1
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "k equals length is min",
      "args": [
        [
          7,
          1,
          9,
          3
        ],
        4
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "single element",
      "args": [
        [
          42
        ],
        1
      ],
      "expected": 42,
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          5,
          5,
          5,
          5
        ],
        3
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -1,
          -5,
          -2,
          -8
        ],
        2
      ],
      "expected": -2,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "kth_largest",
      "starterPath": "problems/heaps-bonus-01/solutions/python/starter.py",
      "referencePath": "problems/heaps-bonus-01/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "kthLargest",
      "starterPath": "problems/heaps-bonus-01/solutions/typescript/starter.ts",
      "referencePath": "problems/heaps-bonus-01/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "KthLargest",
      "starterPath": "problems/heaps-bonus-01/solutions/go/starter.go",
      "referencePath": "problems/heaps-bonus-01/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "kthLargest",
      "starterPath": "problems/heaps-bonus-01/solutions/scala/starter.scala",
      "referencePath": "problems/heaps-bonus-01/solutions/scala/reference.scala"
    }
  }
}
