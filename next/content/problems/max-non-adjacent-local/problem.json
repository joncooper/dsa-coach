{
  "id": "max-non-adjacent-local",
  "kind": "problem",
  "title": "Max Non Adjacent Local",
  "difficulty": "easy",
  "concepts": [
    "DP choice",
    "rolling state"
  ],
  "prompt": "Return the maximum sum obtainable by choosing values with no two chosen values adjacent. Choosing no values is allowed.",
  "signature": {
    "name": "maxNonAdjacentLocal",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "choose spread",
      "args": [
        [
          2,
          7,
          9,
          3
        ]
      ],
      "expected": 11,
      "visibility": "visible"
    },
    {
      "name": "all negative",
      "args": [
        [
          -5,
          -1
        ]
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          8
        ]
      ],
      "expected": 8,
      "visibility": "hidden"
    },
    {
      "name": "two adj",
      "args": [
        [
          5,
          1
        ]
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "five spaced",
      "args": [
        [
          3,
          2,
          5,
          10,
          7
        ]
      ],
      "expected": 15,
      "visibility": "hidden"
    },
    {
      "name": "zeroes",
      "args": [
        [
          0,
          0,
          0,
          0
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "mixed signs",
      "args": [
        [
          -1,
          5,
          -1,
          5,
          -1
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          4,
          4,
          4,
          4,
          4
        ]
      ],
      "expected": 12,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "max_non_adjacent_local",
      "starterPath": "problems/max-non-adjacent-local/solutions/python/starter.py",
      "referencePath": "problems/max-non-adjacent-local/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "maxNonAdjacentLocal",
      "starterPath": "problems/max-non-adjacent-local/solutions/typescript/starter.ts",
      "referencePath": "problems/max-non-adjacent-local/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MaxNonAdjacentLocal",
      "starterPath": "problems/max-non-adjacent-local/solutions/go/starter.go",
      "referencePath": "problems/max-non-adjacent-local/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "maxNonAdjacentLocal",
      "starterPath": "problems/max-non-adjacent-local/solutions/scala/starter.scala",
      "referencePath": "problems/max-non-adjacent-local/solutions/scala/reference.scala"
    }
  }
}
