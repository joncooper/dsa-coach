{
  "id": "count-grid-islands",
  "kind": "problem",
  "title": "Count Grid Islands",
  "difficulty": "medium",
  "concepts": [
    "grid DFS",
    "visited"
  ],
  "prompt": "A grid contains 1 for land and 0 for water. Count 4-directionally connected land masses.",
  "signature": {
    "name": "countGridIslands",
    "inputs": [
      {
        "name": "grid",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three islands",
      "args": [
        [
          [
            1,
            1,
            0
          ],
          [
            0,
            0,
            1
          ],
          [
            1,
            0,
            1
          ]
        ]
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "none",
      "args": [
        [
          [
            0,
            0
          ],
          [
            0,
            0
          ]
        ]
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "one",
      "args": [
        [
          [
            1,
            1
          ],
          [
            1,
            1
          ]
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single-cell-land",
      "args": [
        [
          [
            1
          ]
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "single-cell-water",
      "args": [
        [
          [
            0
          ]
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "diagonal-not-connected",
      "args": [
        [
          [
            1,
            0
          ],
          [
            0,
            1
          ]
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "L-shape",
      "args": [
        [
          [
            1,
            0,
            0
          ],
          [
            1,
            1,
            0
          ],
          [
            0,
            1,
            0
          ]
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "checkerboard",
      "args": [
        [
          [
            1,
            0,
            1
          ],
          [
            0,
            1,
            0
          ],
          [
            1,
            0,
            1
          ]
        ]
      ],
      "expected": 5,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_grid_islands",
      "starterPath": "problems/count-grid-islands/solutions/python/starter.py",
      "referencePath": "problems/count-grid-islands/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countGridIslands",
      "starterPath": "problems/count-grid-islands/solutions/typescript/starter.ts",
      "referencePath": "problems/count-grid-islands/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountGridIslands",
      "starterPath": "problems/count-grid-islands/solutions/go/starter.go",
      "referencePath": "problems/count-grid-islands/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countGridIslands",
      "starterPath": "problems/count-grid-islands/solutions/scala/starter.scala",
      "referencePath": "problems/count-grid-islands/solutions/scala/reference.scala"
    }
  }
}
