{
  "id": "two-pointers-sliding-window-bonus-06",
  "kind": "problem",
  "title": "Longest Substring Without Repeats",
  "difficulty": "medium",
  "concepts": [
    "two-pointers-sliding-window",
    "variable window"
  ],
  "prompt": "Return the length of the longest contiguous substring that contains no repeated character.",
  "signature": {
    "name": "longestUniqueSubstring",
    "inputs": [
      {
        "name": "text",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "repeats break it",
      "args": [
        "abcabcbb"
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "all same",
      "args": [
        "bbbbb"
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        "a"
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "all distinct",
      "args": [
        "abcdef"
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "duplicate spans window",
      "args": [
        "pwwkew"
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "shrink past one char",
      "args": [
        "dvdf"
      ],
      "expected": 3,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "longest_unique_substring",
      "starterPath": "problems/two-pointers-sliding-window-bonus-06/solutions/python/starter.py",
      "referencePath": "problems/two-pointers-sliding-window-bonus-06/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "longestUniqueSubstring",
      "starterPath": "problems/two-pointers-sliding-window-bonus-06/solutions/typescript/starter.ts",
      "referencePath": "problems/two-pointers-sliding-window-bonus-06/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "LongestUniqueSubstring",
      "starterPath": "problems/two-pointers-sliding-window-bonus-06/solutions/go/starter.go",
      "referencePath": "problems/two-pointers-sliding-window-bonus-06/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "longestUniqueSubstring",
      "starterPath": "problems/two-pointers-sliding-window-bonus-06/solutions/scala/starter.scala",
      "referencePath": "problems/two-pointers-sliding-window-bonus-06/solutions/scala/reference.scala"
    }
  }
}
