{
  "id": "dynamic-programming-bonus-01",
  "kind": "problem",
  "title": "Tribonacci Number",
  "difficulty": "warmup",
  "concepts": [
    "dynamic-programming",
    "linear recurrence",
    "tabulation"
  ],
  "prompt": "The Tribonacci sequence starts 0, 1, 1 and every later term is the sum of the previous three. Return the n-th Tribonacci number (0-indexed).",
  "signature": {
    "name": "tribonacci",
    "inputs": [
      {
        "name": "n",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "sixth term",
      "args": [
        6
      ],
      "expected": 13,
      "visibility": "visible"
    },
    {
      "name": "base case two",
      "args": [
        2
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "base zero",
      "args": [
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "base one",
      "args": [
        1
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "third term",
      "args": [
        3
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "fourth term",
      "args": [
        4
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "fifth term",
      "args": [
        5
      ],
      "expected": 7,
      "visibility": "hidden"
    },
    {
      "name": "tenth term",
      "args": [
        10
      ],
      "expected": 149,
      "visibility": "hidden"
    },
    {
      "name": "large index",
      "args": [
        25
      ],
      "expected": 1389537,
      "visibility": "hidden"
    }
  ],
