{
  "id": "running-maximum",
  "kind": "problem",
  "title": "Running Maximum",
  "difficulty": "easy",
  "concepts": ["arrays", "single-pass", "invariants"],
  "prompt": "Given a list of numbers, return a list where each position contains the maximum value seen so far.",
  "signature": {
    "name": "runningMaximum",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": { "type": "number" }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": { "type": "number" }
    }
  },
  "tests": [
    {
      "name": "rises and plateaus",
      "args": [[1, 3, 2, 5, 4]],
      "expected": [1, 3, 3, 5, 5],
      "visibility": "visible"
    },
    {
      "name": "single value",
      "args": [[7]],
      "expected": [7],
      "visibility": "visible"
    },
    {
      "name": "all negative",
      "args": [[-5, -2, -8]],
      "expected": [-5, -2, -2],
      "visibility": "hidden"
    },
    {
      "name": "empty",
      "args": [[]],
      "expected": [],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "typescript": {
      "entrypoint": "runningMaximum",
      "starterPath": "problems/running-maximum/solutions/typescript/starter.ts",
      "referencePath": "problems/running-maximum/solutions/typescript/reference.ts"
    },
    "python": {
      "entrypoint": "running_maximum",
      "starterPath": "problems/running-maximum/solutions/python/starter.py",
      "referencePath": "problems/running-maximum/solutions/python/reference.py"
    },
    "go": {
      "entrypoint": "RunningMaximum",
      "starterPath": "problems/running-maximum/solutions/go/starter.go",
      "referencePath": "problems/running-maximum/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "runningMaximum",
      "starterPath": "problems/running-maximum/solutions/scala/starter.scala",
      "referencePath": "problems/running-maximum/solutions/scala/reference.scala"
    }
  }
}
