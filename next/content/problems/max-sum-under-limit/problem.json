{
  "id": "max-sum-under-limit",
  "kind": "problem",
  "title": "Max Sum Under Limit",
  "difficulty": "medium",
  "concepts": [
    "variable window",
    "positive numbers"
  ],
  "prompt": "All numbers are positive. Return the largest sum of any contiguous subarray with sum less than or equal to `limit`.",
  "signature": {
    "name": "maxSumUnderLimit",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "limit",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "shrink needed",
      "args": [
        [
          2,
          1,
          5,
          2,
          3
        ],
        7
      ],
      "expected": 7,
      "visibility": "visible"
    },
    {
      "name": "all too large",
      "args": [
        [
          9,
          10
        ],
        5
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "whole array",
      "args": [
        [
          1,
          2,
          3
        ],
        10
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "single best",
      "args": [
        [
          4,
          8,
          1
        ],
        8
      ],
      "expected": 8,
      "visibility": "hidden"
    },
    {
      "name": "single under",
      "args": [
        [
          3
        ],
        5
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "exactly limit",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        10
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "empty",
      "args": [
        [],
        5
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "last is best",
      "args": [
        [
          1,
          1,
          1,
          9
        ],
        9
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "limit zero",
      "args": [
        [
          1,
          2,
          3
        ],
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "max_sum_under_limit",
      "starterPath": "problems/max-sum-under-limit/solutions/python/starter.py",
      "referencePath": "problems/max-sum-under-limit/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "maxSumUnderLimit",
      "starterPath": "problems/max-sum-under-limit/solutions/typescript/starter.ts",
      "referencePath": "problems/max-sum-under-limit/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MaxSumUnderLimit",
      "starterPath": "problems/max-sum-under-limit/solutions/go/starter.go",
      "referencePath": "problems/max-sum-under-limit/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "maxSumUnderLimit",
      "starterPath": "problems/max-sum-under-limit/solutions/scala/starter.scala",
      "referencePath": "problems/max-sum-under-limit/solutions/scala/reference.scala"
    }
  }
}
