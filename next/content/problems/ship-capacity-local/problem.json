{
  "id": "ship-capacity-local",
  "kind": "problem",
  "title": "Ship Capacity Local",
  "difficulty": "medium",
  "concepts": [
    "binary search answer",
    "greedy check"
  ],
  "prompt": "Packages must ship in order. Return the minimum ship capacity needed to ship all packages within `days` days.",
  "signature": {
    "name": "shipCapacityLocal",
    "inputs": [
      {
        "name": "weights",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "days",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "basic",
      "args": [
        [
          3,
          2,
          2,
          4,
          1
        ],
        3
      ],
      "expected": 5,
      "visibility": "visible"
    },
    {
      "name": "one day",
      "args": [
        [
          1,
          2,
          3
        ],
        1
      ],
      "expected": 6,
      "visibility": "visible"
    },
    {
      "name": "many days",
      "args": [
        [
          5,
          1,
          1
        ],
        5
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          9
        ],
        2
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "equal weights",
      "args": [
        [
          3,
          3,
          3,
          3
        ],
        2
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "one big one small",
      "args": [
        [
          10,
          1
        ],
        2
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "two days exact",
      "args": [
        [
          1,
          2,
          3,
          1,
          1
        ],
        2
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "days equals packages",
      "args": [
        [
          4,
          4,
          4,
          4
        ],
        4
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "many small one big",
      "args": [
        [
          1,
          1,
          1,
          1,
          5
        ],
        3
      ],
      "expected": 5,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "ship_capacity_local",
      "starterPath": "problems/ship-capacity-local/solutions/python/starter.py",
      "referencePath": "problems/ship-capacity-local/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "shipCapacityLocal",
      "starterPath": "problems/ship-capacity-local/solutions/typescript/starter.ts",
      "referencePath": "problems/ship-capacity-local/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "ShipCapacityLocal",
      "starterPath": "problems/ship-capacity-local/solutions/go/starter.go",
      "referencePath": "problems/ship-capacity-local/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "shipCapacityLocal",
      "starterPath": "problems/ship-capacity-local/solutions/scala/starter.scala",
      "referencePath": "problems/ship-capacity-local/solutions/scala/reference.scala"
    }
  }
}
