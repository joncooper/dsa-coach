{
  "id": "arrays-strings-bonus-05",
  "kind": "problem",
  "title": "Most Frequent Character",
  "difficulty": "easy",
  "concepts": [
    "arrays-strings",
    "string scan",
    "frequency map"
  ],
  "prompt": "Return the character that occurs most often in the string. If several characters tie for the highest count, return the one that appears earliest in the string. Return `null` for an empty string.",
  "signature": {
    "name": "mostFrequentCharacter",
    "inputs": [
      {
        "name": "text",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "string",
      "nullable": true
    }
  },
  "tests": [
    {
      "name": "clear winner",
      "args": [
        "aabbbc"
      ],
      "expected": "b",
      "visibility": "visible"
    },
    {
      "name": "tie picks earliest",
      "args": [
        "abcabc"
      ],
      "expected": "a",
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": null,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        "x"
      ],
      "expected": "x",
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        "zzz"
      ],
      "expected": "z",
      "visibility": "hidden"
    },
    {
      "name": "long word",
      "args": [
        "mississippi"
      ],
      "expected": "i",
      "visibility": "hidden"
    },
    {
      "name": "with spaces",
      "args": [
        "a a b"
      ],
      "expected": "a",
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "most_frequent_character",
      "starterPath": "problems/arrays-strings-bonus-05/solutions/python/starter.py",
      "referencePath": "problems/arrays-strings-bonus-05/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "mostFrequentCharacter",
      "starterPath": "problems/arrays-strings-bonus-05/solutions/typescript/starter.ts",
      "referencePath": "problems/arrays-strings-bonus-05/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MostFrequentCharacter",
      "starterPath": "problems/arrays-strings-bonus-05/solutions/go/starter.go",
      "referencePath": "problems/arrays-strings-bonus-05/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "mostFrequentCharacter",
      "starterPath": "problems/arrays-strings-bonus-05/solutions/scala/starter.scala",
      "referencePath": "problems/arrays-strings-bonus-05/solutions/scala/reference.scala"
    }
  }
}
