{
  "id": "foundations-bonus-12",
  "kind": "problem",
  "title": "Collatz Step Count",
  "difficulty": "easy",
  "concepts": [
    "foundations",
    "iteration",
    "Big O"
  ],
  "prompt": "Starting from a positive integer, repeatedly halve it when it is even or triple it and add one when it is odd. Return how many steps it takes to reach 1.",
  "signature": {
    "name": "collatzSteps",
    "inputs": [
      {
        "name": "n",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three",
      "args": [
        3
      ],
      "expected": 7,
      "visibility": "visible"
    },
    {
      "name": "already one",
      "args": [
        1
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "two",
      "args": [
        2
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "six",
      "args": [
        6
      ],
      "expected": 8,
      "visibility": "hidden"
    },
    {
      "name": "seven",
      "args": [
        7
      ],
      "expected": 16,
      "visibility": "hidden"
    },
    {
      "name": "power of two",
      "args": [
        16
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "nine",
      "args": [
        9
      ],
      "expected": 19,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "collatz_steps",
      "starterPath": "problems/foundations-bonus-12/solutions/python/starter.py",
      "referencePath": "problems/foundations-bonus-12/solutions/python/reference.py"
    },
    "typescript": {
