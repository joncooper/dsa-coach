      "referencePath": "problems/heaps-bonus-07/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "KWeakestRows",
      "starterPath": "problems/heaps-bonus-07/solutions/go/starter.go",
      "referencePath": "problems/heaps-bonus-07/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "kWeakestRows",
      "starterPath": "problems/heaps-bonus-07/solutions/scala/starter.scala",
      "referencePath": "problems/heaps-bonus-07/solutions/scala/reference.scala"
    }
  }
}
