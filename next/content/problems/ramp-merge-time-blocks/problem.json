{
  "id": "ramp-merge-time-blocks",
  "kind": "problem",
  "title": "Merge Time Blocks",
  "difficulty": "medium",
  "concepts": [
    "intervals",
    "sorting",
    "merge intervals"
  ],
  "prompt": "Imagine you are building a small scheduling tool. It receives a list of busy time blocks, but the blocks may be out of order and some of them overlap.\n\nEach block is `[start, end]`, where `start` and `end` are integer timestamps and the block covers the half-open interval `[start, end)`. For example, `[10, 14]` covers time from 10 up to, but not including, 14.\n\nWrite `mergeTimeBlocks(blocks)` so it returns the same busy time, but with overlapping blocks merged together and sorted by start time.\n\nIf two blocks touch exactly, treat them as one continuous busy block. For example, `[1, 3]` and `[3, 5]` should become `[1, 5]` because there is no free gap between them.\n\nReturn a list of `[start, end]` blocks. If the input is empty, return an empty list.",
  "signature": {
    "name": "mergeTimeBlocks",
    "inputs": [
      {
        "name": "blocks",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number"
        }
      }
    }
  },
  "tests": [
    {
      "name": "unsorted overlaps",
      "args": [
        [
          [
            5,
            7
          ],
          [
            1,
            3
          ],
          [
            2,
            6
          ],
          [
            10,
            12
          ]
        ]
      ],
      "expected": [
        [
          1,
          7
        ],
        [
          10,
          12
        ]
      ],
      "visibility": "visible"
    },
    {
      "name": "touching blocks",
      "args": [
        [
          [
            1,
            2
          ],
          [
            2,
            4
          ],
          [
            6,
            7
          ]
        ]
      ],
      "expected": [
        [
          1,
          4
        ],
        [
          6,
          7
        ]
      ],
      "visibility": "visible"
    },
    {
      "name": "empty input",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "nested blocks",
      "args": [
        [
          [
            1,
            10
          ],
          [
            2,
            3
          ],
          [
            4,
            8
          ]
        ]
      ],
      "expected": [
        [
          1,
          10
        ]
      ],
      "visibility": "hidden"
    },
    {
      "name": "negative timestamps",
      "args": [
        [
          [
            -5,
            -1
          ],
          [
            -3,
            2
          ],
          [
            4,
            5
          ]
        ]
      ],
      "expected": [
        [
          -5,
          2
        ],
        [
          4,
          5
        ]
      ],
      "visibility": "hidden"
    },
    {
      "name": "same start and touching tail",
      "args": [
        [
          [
            1,
            4
          ],
          [
            1,
            2
          ],
          [
            4,
            5
          ],
          [
            6,
            8
          ]
        ]
      ],
      "expected": [
        [
          1,
          5
        ],
        [
          6,
          8
        ]
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "merge_time_blocks",
      "starterPath": "problems/ramp-merge-time-blocks/solutions/python/starter.py",
      "referencePath": "problems/ramp-merge-time-blocks/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "mergeTimeBlocks",
      "starterPath": "problems/ramp-merge-time-blocks/solutions/typescript/starter.ts",
      "referencePath": "problems/ramp-merge-time-blocks/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MergeTimeBlocks",
      "starterPath": "problems/ramp-merge-time-blocks/solutions/go/starter.go",
      "referencePath": "problems/ramp-merge-time-blocks/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "mergeTimeBlocks",
      "starterPath": "problems/ramp-merge-time-blocks/solutions/scala/starter.scala",
      "referencePath": "problems/ramp-merge-time-blocks/solutions/scala/reference.scala"
    }
  }
}
