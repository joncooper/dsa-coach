{
  "id": "dynamic-programming-bonus-12",
  "kind": "problem",
  "title": "Stock Profit With Cooldown",
  "difficulty": "medium",
  "concepts": [
    "dynamic-programming",
    "state machine",
    "optimization"
  ],
  "prompt": "Given daily stock prices, return the maximum profit from any number of buy-then-sell trades. You may hold at most one share at a time, and after selling you must rest for one full day before buying again.",
  "signature": {
    "name": "maxProfitWithCooldown",
    "inputs": [
      {
        "name": "prices",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "profitable with cooldown",
      "args": [
        [
          1,
          2,
          3,
          0,
          2
        ]
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "strictly falling",
      "args": [
        [
          5,
          4,
          3,
          2,
          1
        ]
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single day",
      "args": [
        [
          1
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "two day drop",
      "args": [
        [
          2,
          1
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "monotone rise",
      "args": [
        [
          1,
          2,
          3,
          4,
          5
        ]
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "spike then dip",
      "args": [
        [
          1,
          4,
          2
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "two trades",
      "args": [
        [
          6,
          1,
          3,
          2,
          4,
          7
        ]
      ],
      "expected": 6,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "max_profit_with_cooldown",
      "starterPath": "problems/dynamic-programming-bonus-12/solutions/python/starter.py",
      "referencePath": "problems/dynamic-programming-bonus-12/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "maxProfitWithCooldown",
      "starterPath": "problems/dynamic-programming-bonus-12/solutions/typescript/starter.ts",
      "referencePath": "problems/dynamic-programming-bonus-12/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MaxProfitWithCooldown",
      "starterPath": "problems/dynamic-programming-bonus-12/solutions/go/starter.go",
      "referencePath": "problems/dynamic-programming-bonus-12/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "maxProfitWithCooldown",
      "starterPath": "problems/dynamic-programming-bonus-12/solutions/scala/starter.scala",
      "referencePath": "problems/dynamic-programming-bonus-12/solutions/scala/reference.scala"
    }
  }
}
