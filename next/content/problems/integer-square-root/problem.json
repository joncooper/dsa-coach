{
  "id": "integer-square-root",
  "kind": "problem",
  "title": "Integer Square Root",
  "difficulty": "easy",
  "concepts": [
    "binary search",
    "integer math"
  ],
  "prompt": "Return the greatest integer `x` such that `x * x <= n` for non-negative integer `n`.",
  "signature": {
    "name": "integerSquareRoot",
    "inputs": [
      {
        "name": "n",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "not perfect",
      "args": [
        20
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "perfect",
      "args": [
        49
      ],
      "expected": 7,
      "visibility": "visible"
    },
    {
      "name": "zero",
      "args": [
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "one",
      "args": [
        1
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "two",
      "args": [
        2
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "three",
      "args": [
        3
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "four",
      "args": [
        4
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "hundred",
      "args": [
        100
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "just under perfect",
      "args": [
        99
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "large",
      "args": [
        1000000
      ],
      "expected": 1000,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "integer_square_root",
      "starterPath": "problems/integer-square-root/solutions/python/starter.py",
      "referencePath": "problems/integer-square-root/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "integerSquareRoot",
      "starterPath": "problems/integer-square-root/solutions/typescript/starter.ts",
      "referencePath": "problems/integer-square-root/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "IntegerSquareRoot",
      "starterPath": "problems/integer-square-root/solutions/go/starter.go",
      "referencePath": "problems/integer-square-root/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "integerSquareRoot",
      "starterPath": "problems/integer-square-root/solutions/scala/starter.scala",
      "referencePath": "problems/integer-square-root/solutions/scala/reference.scala"
    }
  }
}
