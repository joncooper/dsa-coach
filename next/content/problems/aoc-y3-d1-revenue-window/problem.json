{
  "id": "aoc-y3-d1-revenue-window",
  "kind": "problem",
  "title": "Day 1: Revenue Window",
  "difficulty": "warmup",
  "concepts": [
    "parsing",
    "sliding window",
    "max"
  ],
  "prompt": "The input is one integer revenue figure per non-empty line. The first non-empty line is the window size `k`. Every following non-empty line is one day's revenue. Return the maximum sum of any contiguous window of exactly `k` consecutive days. Return 0 if fewer than `k` days are present.",
  "signature": {
    "name": "max_revenue_window",
    "inputs": [
      {
        "name": "inputText",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "best window of three",
      "args": [
        "3\n1\n2\n3\n4\n5"
      ],
      "expected": 12,
      "visibility": "visible"
    },
    {
      "name": "single day window",
      "args": [
        "1\n5\n9\n3"
      ],
      "expected": 9,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "fewer days than k",
      "args": [
        "5\n1\n2"
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "negative values",
      "args": [
        "2\n-1\n-2\n-3\n10"
      ],
      "expected": 7,
      "visibility": "hidden"
    },
    {
      "name": "exact fit",
      "args": [
        "3\n1\n2\n3"
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "zeros around peak",
      "args": [
        "2\n0\n5\n5\n0"
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "all negative",
      "args": [
        "2\n-5\n-3\n-9\n-1"
      ],
      "expected": -8,
      "visibility": "hidden"
    },
    {
      "name": "k equals one returns max element",
      "args": [
        "1\n3\n7\n2\n9\n4"
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "k equals length",
      "args": [
        "4\n1\n2\n3\n4"
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "peak in middle of stream",
      "args": [
        "3\n1\n2\n3\n100\n1\n1\n1"
      ],
      "expected": 105,
      "visibility": "hidden"
    },
    {
      "name": "single value below k zero",
      "args": [
        "3\n5"
      ],
      "expected": 0,
      "visibility": "hidden"
    }
  ],
  "parts": [
    {
      "id": "part-2-count-good-windows",
      "title": "Part 2: Count winning windows",
      "prompt": "Same input. Now return the count of windows of size `k` whose sum is strictly greater than the sum of the immediately previous window of size `k`. The first window has no previous window and is never counted.",
      "signature": {
        "name": "rising_windows",
        "inputs": [
          {
            "name": "inputText",
            "type": {
              "type": "string"
            }
          }
        ],
        "output": {
          "type": "number"
        }
      },
      "tests": [
        {
          "name": "increasing days",
          "args": [
            "3\n1\n2\n3\n4\n5"
          ],
          "expected": 2,
          "visibility": "visible"
        },
        {
          "name": "no rises",
          "args": [
            "2\n5\n5\n5\n5"
          ],
          "expected": 0,
          "visibility": "visible"
        },
        {
          "name": "empty",
          "args": [
            ""
          ],
          "expected": 0,
          "visibility": "visible"
        },
        {
          "name": "exact fit no second window",
          "args": [
            "3\n1\n2\n3"
          ],
          "expected": 0,
          "visibility": "visible"
        },
        {
          "name": "noisy rise",
          "args": [
            "2\n1\n2\n0\n5"
          ],
          "expected": 1,
          "visibility": "hidden"
        },
        {
          "name": "always falling",
          "args": [
            "1\n5\n4\n3\n2"
          ],
          "expected": 0,
          "visibility": "hidden"
        },
        {
          "name": "all equal",
          "args": [
            "3\n3\n3\n3\n3\n3"
          ],
          "expected": 0,
          "visibility": "hidden"
        },
        {
          "name": "negatives still rise",
          "args": [
            "2\n-10\n0\n5\n-1"
          ],
          "expected": 1,
          "visibility": "hidden"
        },
        {
          "name": "one window after first is just one comparison",
          "args": [
            "3\n1\n2\n3\n4"
          ],
          "expected": 1,
          "visibility": "hidden"
        },
        {
          "name": "tie does not count as rise",
          "args": [
            "2\n1\n1\n1\n1"
          ],
          "expected": 0,
          "visibility": "hidden"
        },
        {
          "name": "long stream alternating rise fall",
          "args": [
            "1\n1\n2\n1\n2\n1\n2"
          ],
          "expected": 3,
          "visibility": "hidden"
        }
      ],
      "languages": {
        "python": {
          "entrypoint": "rising_windows",
          "starterPath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/python/starter.py",
          "referencePath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/python/reference.py"
        },
        "typescript": {
          "entrypoint": "rising_windows",
          "starterPath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/typescript/starter.ts",
          "referencePath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/typescript/reference.ts"
        },
        "go": {
          "entrypoint": "RisingWindows",
          "starterPath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/go/starter.go",
          "referencePath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/go/reference.go"
        },
        "scala": {
          "entrypoint": "rising_windows",
          "starterPath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/scala/starter.scala",
          "referencePath": "problems/aoc-y3-d1-revenue-window/parts/part-2-count-good-windows/solutions/scala/reference.scala"
        }
      }
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "max_revenue_window",
      "starterPath": "problems/aoc-y3-d1-revenue-window/solutions/python/starter.py",
      "referencePath": "problems/aoc-y3-d1-revenue-window/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "max_revenue_window",
      "starterPath": "problems/aoc-y3-d1-revenue-window/solutions/typescript/starter.ts",
      "referencePath": "problems/aoc-y3-d1-revenue-window/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MaxRevenueWindow",
      "starterPath": "problems/aoc-y3-d1-revenue-window/solutions/go/starter.go",
      "referencePath": "problems/aoc-y3-d1-revenue-window/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "max_revenue_window",
      "starterPath": "problems/aoc-y3-d1-revenue-window/solutions/scala/starter.scala",
      "referencePath": "problems/aoc-y3-d1-revenue-window/solutions/scala/reference.scala"
    }
  }
}
