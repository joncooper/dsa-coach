        },
        "go": {
          "entrypoint": "VersionedKvWithSnapshot",
          "starterPath": "problems/tek-versioned-kv/parts/part-2-delete-snapshot/solutions/go/starter.go",
          "referencePath": "problems/tek-versioned-kv/parts/part-2-delete-snapshot/solutions/go/reference.go"
        },
        "scala": {
          "entrypoint": "versioned_kv_with_snapshot",
          "starterPath": "problems/tek-versioned-kv/parts/part-2-delete-snapshot/solutions/scala/starter.scala",
          "referencePath": "problems/tek-versioned-kv/parts/part-2-delete-snapshot/solutions/scala/reference.scala"
        }
