{
  "id": "greedy-bonus-01",
  "kind": "problem",
  "title": "Fewest Coins For An Amount",
  "difficulty": "warmup",
  "concepts": [
    "greedy",
    "sorting",
    "exchange argument"
  ],
  "prompt": "You have an unlimited supply of each coin denomination in `coins`, drawn from a canonical system where every larger coin is a whole-number multiple of the next smaller one (for example 1, 5, 10, 25). Return the fewest coins whose values sum exactly to `amount`. Return 0 when the amount is 0.",
  "signature": {
    "name": "fewestCoins",
    "inputs": [
      {
        "name": "coins",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "amount",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "standard change",
      "args": [
        [
          1,
          5,
          10,
          25
        ],
        63
      ],
      "expected": 6,
      "visibility": "visible"
    },
    {
      "name": "exact single coin",
      "args": [
        [
          1,
          5,
          10,
          25
        ],
        25
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "zero amount",
      "args": [
        [
          1,
          5,
          10,
          25
        ],
        0
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "only pennies needed",
      "args": [
        [
          1,
          5,
          10,
          25
        ],
        4
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "powers of two",
      "args": [
        [
          1,
          2,
          4,
          8
        ],
        15
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "single denomination",
      "args": [
        [
          1
        ],
        7
      ],
      "expected": 7,
      "visibility": "hidden"
    },
    {
      "name": "unsorted input",
      "args": [
        [
          10,
          1,
          25,
          5
        ],
        99
      ],
      "expected": 9,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "fewest_coins",
      "starterPath": "problems/greedy-bonus-01/solutions/python/starter.py",
      "referencePath": "problems/greedy-bonus-01/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "fewestCoins",
      "starterPath": "problems/greedy-bonus-01/solutions/typescript/starter.ts",
      "referencePath": "problems/greedy-bonus-01/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "FewestCoins",
      "starterPath": "problems/greedy-bonus-01/solutions/go/starter.go",
      "referencePath": "problems/greedy-bonus-01/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "fewestCoins",
      "starterPath": "problems/greedy-bonus-01/solutions/scala/starter.scala",
      "referencePath": "problems/greedy-bonus-01/solutions/scala/reference.scala"
    }
  }
}
