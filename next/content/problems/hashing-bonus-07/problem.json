{
  "id": "hashing-bonus-07",
  "kind": "problem",
  "title": "Character Frequency Table",
  "difficulty": "warmup",
  "concepts": [
    "hashing",
    "frequency map",
    "string scans"
  ],
  "prompt": "Return an object/map from each character of the string to the number of times it occurs. Characters that never appear are simply absent from the map.",
  "signature": {
    "name": "charFrequencyTable",
    "inputs": [
      {
        "name": "text",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "object"
    }
  },
  "tests": [
    {
      "name": "mixed letters",
      "args": [
        "aabbc"
      ],
      "expected": {
        "a": 2,
        "b": 2,
        "c": 1
      },
      "visibility": "visible"
    },
    {
      "name": "all distinct",
      "args": [
        "xyz"
      ],
      "expected": {
        "x": 1,
        "y": 1,
        "z": 1
      },
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": {},
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        "a"
      ],
      "expected": {
        "a": 1
      },
      "visibility": "hidden"
    },
    {
      "name": "all same",
      "args": [
        "aaaa"
      ],
      "expected": {
        "a": 4
      },
      "visibility": "hidden"
    },
    {
      "name": "case sensitive",
      "args": [
        "aA"
      ],
      "expected": {
        "a": 1,
        "A": 1
      },
      "visibility": "hidden"
    },
    {
      "name": "spaces count",
      "args": [
        "  "
      ],
      "expected": {
        " ": 2
      },
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "char_frequency_table",
      "starterPath": "problems/hashing-bonus-07/solutions/python/starter.py",
      "referencePath": "problems/hashing-bonus-07/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "charFrequencyTable",
      "starterPath": "problems/hashing-bonus-07/solutions/typescript/starter.ts",
      "referencePath": "problems/hashing-bonus-07/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CharFrequencyTable",
      "starterPath": "problems/hashing-bonus-07/solutions/go/starter.go",
      "referencePath": "problems/hashing-bonus-07/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "charFrequencyTable",
      "starterPath": "problems/hashing-bonus-07/solutions/scala/starter.scala",
      "referencePath": "problems/hashing-bonus-07/solutions/scala/reference.scala"
    }
  }
}
