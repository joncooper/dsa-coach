{
  "id": "foundations-bonus-04",
  "kind": "problem",
  "title": "Factorial",
  "difficulty": "warmup",
  "concepts": [
    "foundations",
    "recursion",
    "base case"
  ],
  "prompt": "Return n factorial (the product of every integer from 1 to n) using recursion. By definition the factorial of 0 is 1.",
  "signature": {
    "name": "factorial",
    "inputs": [
      {
        "name": "n",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "five",
      "args": [
        5
      ],
      "expected": 120,
      "visibility": "visible"
    },
    {
      "name": "zero",
      "args": [
        0
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "one",
      "args": [
        1
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "three",
      "args": [
        3
      ],
      "expected": 6,
      "visibility": "hidden"
    },
    {
      "name": "four",
      "args": [
        4
      ],
      "expected": 24,
      "visibility": "hidden"
    },
    {
      "name": "six",
      "args": [
        6
      ],
      "expected": 720,
      "visibility": "hidden"
    },
    {
      "name": "ten",
      "args": [
        10
      ],
      "expected": 3628800,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
