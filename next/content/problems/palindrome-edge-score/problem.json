{
  "id": "palindrome-edge-score",
  "kind": "problem",
  "title": "Palindrome Edge Score",
  "difficulty": "easy",
  "concepts": [
    "two pointers",
    "palindrome"
  ],
  "prompt": "Compare characters from both ends while they match. Return how many matching pairs are consumed before the first mismatch. A center character does not count as a pair.",
  "signature": {
    "name": "palindromeEdgeScore",
    "inputs": [
      {
        "name": "text",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three pairs",
      "args": [
        "abccba"
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "one pair",
      "args": [
        "abca"
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "none",
      "args": [
        "road"
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "odd",
      "args": [
        "level"
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single char",
      "args": [
        "a"
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "two same",
      "args": [
        "xx"
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "two different",
      "args": [
        "ab"
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "long palindrome",
      "args": [
        "racecar"
      ],
      "expected": 3,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "palindrome_edge_score",
      "starterPath": "problems/palindrome-edge-score/solutions/python/starter.py",
      "referencePath": "problems/palindrome-edge-score/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "palindromeEdgeScore",
      "starterPath": "problems/palindrome-edge-score/solutions/typescript/starter.ts",
      "referencePath": "problems/palindrome-edge-score/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "PalindromeEdgeScore",
      "starterPath": "problems/palindrome-edge-score/solutions/go/starter.go",
      "referencePath": "problems/palindrome-edge-score/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "palindromeEdgeScore",
      "starterPath": "problems/palindrome-edge-score/solutions/scala/starter.scala",
      "referencePath": "problems/palindrome-edge-score/solutions/scala/reference.scala"
    }
  }
}
