{
  "id": "dynamic-programming-bonus-05",
  "kind": "problem",
  "title": "Subset Sum Reachable",
  "difficulty": "medium",
  "concepts": [
    "dynamic-programming",
    "subset sum",
    "knapsack"
  ],
  "prompt": "Given a list of integers and a target, return `true` if some subset of the list sums exactly to the target, and `false` otherwise. The empty subset sums to 0.",
  "signature": {
    "name": "subsetSumReachable",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "target",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "boolean"
    }
  },
  "tests": [
    {
      "name": "subset exists",
      "args": [
        [
          3,
          34,
          4,
          12,
          5,
          2
        ],
        9
      ],
      "expected": true,
      "visibility": "visible"
    },
    {
      "name": "no subset",
      "args": [
        [
          3,
          34,
          4,
          12,
          5,
          2
        ],
        30
      ],
      "expected": false,
      "visibility": "visible"
    },
    {
      "name": "empty list zero target",
      "args": [
        [],
        0
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "empty list nonzero target",
      "args": [
        [],
        5
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "single matches",
      "args": [
        [
          5
        ],
        5
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "single misses",
      "args": [
        [
          5
        ],
        3
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "use everything",
      "args": [
        [
          1,
          2,
          3
        ],
        6
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "parity blocks odd",
      "args": [
        [
          2,
          4,
          6
        ],
        5
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "zero target with items",
      "args": [
        [
          7,
          3
        ],
        0
      ],
      "expected": true,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "subset_sum_reachable",
      "starterPath": "problems/dynamic-programming-bonus-05/solutions/python/starter.py",
      "referencePath": "problems/dynamic-programming-bonus-05/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "subsetSumReachable",
      "starterPath": "problems/dynamic-programming-bonus-05/solutions/typescript/starter.ts",
      "referencePath": "problems/dynamic-programming-bonus-05/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "SubsetSumReachable",
      "starterPath": "problems/dynamic-programming-bonus-05/solutions/go/starter.go",
      "referencePath": "problems/dynamic-programming-bonus-05/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "subsetSumReachable",
      "starterPath": "problems/dynamic-programming-bonus-05/solutions/scala/starter.scala",
      "referencePath": "problems/dynamic-programming-bonus-05/solutions/scala/reference.scala"
    }
  }
}
