  "parts": [
    {
      "id": "l2-scan",
      "title": "Level 2: Scan & prefix scan",
      "prompt": "Extend the store with field-level scans. All Level 1 operations keep working.\n\n**New operations**\n\n- `[\"SCAN\", timestamp, key]` — return every field of `key` formatted as `field=value`, joined by commas, **sorted by field name ascending**. Return `\"\"` if the key has no fields (or does not exist).\n- `[\"SCAN_BY_PREFIX\", timestamp, key, prefix]` — same, but only fields whose name starts with `prefix`. Return `\"\"` if the key is absent or no field matches. An empty prefix matches every field.",
      "signature": {
        "name": "solution",
        "inputs": [
          {
            "name": "queries",
            "type": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "output": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "tests": [
        {
          "name": "l2-scan-single-field",
          "args": [
            [
              [
                "SET",
                "1",
                "user:1",
                "name",
                "alice"
              ],
              [
                "SCAN",
                "2",
                "user:1"
              ]
            ]
          ],
          "expected": [
            "true",
            "name=alice"
          ],
          "visibility": "visible"
        },
        {
          "name": "l2-scan-multi-sorted",
          "args": [
            [
              [
                "SET",
                "1",
                "user:1",
                "name",
                "alice"
              ],
              [
                "SET",
                "2",
                "user:1",
                "email",
                "a@x"
              ],
              [
                "SET",
                "3",
                "user:1",
                "age",
                "30"
              ],
              [
                "SCAN",
                "4",
                "user:1"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "true",
            "age=30,email=a@x,name=alice"
          ],
          "visibility": "visible"
        },
        {
          "name": "l2-scan-missing-key",
          "args": [
            [
              [
                "SCAN",
                "1",
                "ghost"
              ]
            ]
