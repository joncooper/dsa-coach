                "email",
                "a@x"
              ],
              [
                "SCAN_BY_PREFIX",
                "4",
                "user:1",
                "first"
              ]
            ]
          ],
          "expected": [
            "true",
            "true",
            "true",
            "first_name=alice"
          ],
          "visibility": "visible"
        },
        {
          "name": "l2-prefix-no-match",
          "args": [
            [
              [
                "SET",
                "1",
                "user:1",
                "name",
                "alice"
              ],
              [
                "SCAN_BY_PREFIX",
                "2",
                "user:1",
                "zzz"
              ]
            ]
          ],
          "expected": [
            "true",
            ""
          ],
          "visibility": "hidden"
        },
        {
