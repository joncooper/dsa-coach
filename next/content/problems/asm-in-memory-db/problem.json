          "referencePath": "problems/asm-in-memory-db/parts/l3-ttl/solutions/typescript/reference.ts"
        },
        "go": {
          "entrypoint": "Solution",
          "starterPath": "problems/asm-in-memory-db/parts/l3-ttl/solutions/go/starter.go",
          "referencePath": "problems/asm-in-memory-db/parts/l3-ttl/solutions/go/reference.go"
