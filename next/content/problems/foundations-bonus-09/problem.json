{
  "id": "foundations-bonus-09",
  "kind": "problem",
  "title": "Count Distinct Values",
  "difficulty": "warmup",
  "concepts": [
    "foundations",
    "test design",
    "iteration"
  ],
  "prompt": "Return how many distinct values appear in the list. Repeated values are counted only once.",
  "signature": {
    "name": "countDistinct",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "repeats collapse",
      "args": [
        [
          1,
          2,
          2,
          3,
          3,
          3
        ]
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "all unique",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          7
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          5,
          5,
          5
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "negatives and zero",
      "args": [
        [
          -1,
          -1,
          0,
          0
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "interleaved",
      "args": [
        [
          9,
          8,
          9,
          8,
          7
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_distinct",
      "starterPath": "problems/foundations-bonus-09/solutions/python/starter.py",
      "referencePath": "problems/foundations-bonus-09/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countDistinct",
      "starterPath": "problems/foundations-bonus-09/solutions/typescript/starter.ts",
      "referencePath": "problems/foundations-bonus-09/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountDistinct",
      "starterPath": "problems/foundations-bonus-09/solutions/go/starter.go",
      "referencePath": "problems/foundations-bonus-09/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countDistinct",
      "starterPath": "problems/foundations-bonus-09/solutions/scala/starter.scala",
      "referencePath": "problems/foundations-bonus-09/solutions/scala/reference.scala"
    }
  }
}
