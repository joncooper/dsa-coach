{
  "id": "stacks-queues-bonus-03",
  "kind": "problem",
  "title": "Collapse Adjacent Duplicates",
  "difficulty": "easy",
  "concepts": [
    "stacks-queues",
    "stack"
  ],
  "prompt": "Repeatedly remove any two adjacent equal characters from the string. Removals can expose new adjacent pairs, which are also removed. Return the final string once no adjacent pair remains.",
  "signature": {
    "name": "collapseDuplicates",
    "inputs": [
      {
        "name": "text",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "string"
    }
  },
  "tests": [
    {
      "name": "single collapse",
      "args": [
        "abbaca"
      ],
      "expected": "ca",
      "visibility": "visible"
    },
    {
      "name": "no duplicates",
      "args": [
        "abc"
      ],
      "expected": "abc",
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        ""
      ],
      "expected": "",
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        "a"
      ],
      "expected": "a",
      "visibility": "hidden"
    },
    {
      "name": "all cancel",
      "args": [
        "aaaa"
      ],
      "expected": "",
      "visibility": "hidden"
    },
    {
      "name": "chain reaction",
      "args": [
        "aabccba"
      ],
      "expected": "a",
      "visibility": "hidden"
    },
    {
      "name": "odd run",
      "args": [
        "aaa"
      ],
      "expected": "a",
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "collapse_duplicates",
      "starterPath": "problems/stacks-queues-bonus-03/solutions/python/starter.py",
      "referencePath": "problems/stacks-queues-bonus-03/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "collapseDuplicates",
      "starterPath": "problems/stacks-queues-bonus-03/solutions/typescript/starter.ts",
      "referencePath": "problems/stacks-queues-bonus-03/solutions/typescript/reference.ts"
    },
    "go": {
