      "starterPath": "problems/stacks-queues-bonus-03/solutions/go/starter.go",
      "referencePath": "problems/stacks-queues-bonus-03/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "collapseDuplicates",
      "starterPath": "problems/stacks-queues-bonus-03/solutions/scala/starter.scala",
      "referencePath": "problems/stacks-queues-bonus-03/solutions/scala/reference.scala"
    }
  }
}
