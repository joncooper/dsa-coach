{
  "id": "rotate-left-local",
  "kind": "problem",
  "title": "Rotate Left Local",
  "difficulty": "easy",
  "concepts": [
    "array transform",
    "modulo"
  ],
  "prompt": "Return a new array containing `nums` rotated left by `k` positions. Do not mutate the input.",
  "signature": {
    "name": "rotateLeft",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "k",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "basic",
      "args": [
        [
          1,
          2,
          3,
          4,
          5
        ],
        2
      ],
      "expected": [
        3,
        4,
        5,
        1,
        2
      ],
      "visibility": "visible"
    },
    {
      "name": "large k",
      "args": [
        [
          1,
          2,
          3
        ],
        5
      ],
      "expected": [
        3,
        1,
        2
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        3
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "zero",
      "args": [
        [
          4,
          5
        ],
        0
      ],
      "expected": [
        4,
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "single element",
      "args": [
        [
          7
        ],
        4
      ],
      "expected": [
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "k equals length",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        4
      ],
      "expected": [
        1,
        2,
        3,
        4
      ],
      "visibility": "hidden"
    },
    {
      "name": "k one",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        1
      ],
      "expected": [
        2,
        3,
        4,
        1
      ],
      "visibility": "hidden"
    },
    {
      "name": "k equals length minus one",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        3
      ],
      "expected": [
        4,
        1,
        2,
        3
      ],
      "visibility": "hidden"
    },
    {
      "name": "duplicates",
      "args": [
        [
          5,
          5,
          5,
          5
        ],
        2
      ],
      "expected": [
        5,
        5,
        5,
        5
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "rotate_left",
      "starterPath": "problems/rotate-left-local/solutions/python/starter.py",
      "referencePath": "problems/rotate-left-local/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "rotateLeft",
      "starterPath": "problems/rotate-left-local/solutions/typescript/starter.ts",
      "referencePath": "problems/rotate-left-local/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "RotateLeft",
      "starterPath": "problems/rotate-left-local/solutions/go/starter.go",
      "referencePath": "problems/rotate-left-local/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "rotateLeft",
      "starterPath": "problems/rotate-left-local/solutions/scala/starter.scala",
      "referencePath": "problems/rotate-left-local/solutions/scala/reference.scala"
    }
  }
}
