      "starterPath": "problems/heaps-bonus-10/solutions/typescript/starter.ts",
      "referencePath": "problems/heaps-bonus-10/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MaxScoreAfterHalving",
      "starterPath": "problems/heaps-bonus-10/solutions/go/starter.go",
      "referencePath": "problems/heaps-bonus-10/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "maxScoreAfterHalving",
      "starterPath": "problems/heaps-bonus-10/solutions/scala/starter.scala",
      "referencePath": "problems/heaps-bonus-10/solutions/scala/reference.scala"
    }
  }
}
