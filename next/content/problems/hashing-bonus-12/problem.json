{
  "id": "hashing-bonus-12",
  "kind": "problem",
  "title": "Isomorphic Strings",
  "difficulty": "medium",
  "concepts": [
    "hashing",
    "bijection map",
    "canonical key"
  ],
  "prompt": "Two strings are isomorphic if the characters of the first can be consistently replaced to produce the second: every occurrence of a character maps to the same character, and no two distinct characters map to the same one. Return True if the strings are isomorphic.",
  "signature": {
    "name": "isomorphicStrings",
    "inputs": [
      {
        "name": "source",
        "type": {
          "type": "string"
        }
      },
      {
        "name": "target",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "boolean"
    }
  },
  "tests": [
    {
      "name": "isomorphic",
      "args": [
        "egg",
        "add"
      ],
      "expected": true,
      "visibility": "visible"
    },
    {
      "name": "not isomorphic",
      "args": [
        "foo",
        "bar"
      ],
      "expected": false,
      "visibility": "visible"
    },
    {
      "name": "both empty",
      "args": [
        "",
        ""
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "single chars",
      "args": [
        "a",
        "b"
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "target collision",
      "args": [
        "ab",
        "aa"
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "longer pair",
      "args": [
        "paper",
        "title"
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "length mismatch",
      "args": [
        "abc",
        "abcd"
      ],
      "expected": false,
      "visibility": "hidden"
    },
    {
      "name": "same pattern",
      "args": [
        "aba",
        "xyx"
      ],
      "expected": true,
      "visibility": "hidden"
    },
    {
      "name": "source collision",
      "args": [
        "badc",
        "baba"
      ],
      "expected": false,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "isomorphic_strings",
      "starterPath": "problems/hashing-bonus-12/solutions/python/starter.py",
      "referencePath": "problems/hashing-bonus-12/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "isomorphicStrings",
      "starterPath": "problems/hashing-bonus-12/solutions/typescript/starter.ts",
      "referencePath": "problems/hashing-bonus-12/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "IsomorphicStrings",
      "starterPath": "problems/hashing-bonus-12/solutions/go/starter.go",
      "referencePath": "problems/hashing-bonus-12/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "isomorphicStrings",
      "starterPath": "problems/hashing-bonus-12/solutions/scala/starter.scala",
      "referencePath": "problems/hashing-bonus-12/solutions/scala/reference.scala"
    }
  }
}
