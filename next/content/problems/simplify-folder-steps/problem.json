{
  "id": "simplify-folder-steps",
  "kind": "problem",
  "title": "Simplify Folder Steps",
  "difficulty": "easy",
  "concepts": [
    "stack",
    "simulation"
  ],
  "prompt": "Given folder steps where `..` means move up, `.` means stay, and any other token is a folder name, return the simplified absolute path beginning with `/`.",
  "signature": {
    "name": "simplifyFolderSteps",
    "inputs": [
      {
        "name": "steps",
        "type": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    ],
    "output": {
      "type": "string"
    }
  },
  "tests": [
    {
      "name": "mixed",
      "args": [
        [
          "home",
          ".",
          "code",
          "..",
          "docs"
        ]
      ],
      "expected": "/home/docs",
      "visibility": "visible"
    },
    {
      "name": "above root",
      "args": [
        [
          "..",
          "..",
          "x"
        ]
      ],
      "expected": "/x",
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": "/",
      "visibility": "hidden"
    },
    {
      "name": "all removed",
      "args": [
        [
          "a",
          ".."
        ]
      ],
      "expected": "/",
      "visibility": "hidden"
    },
    {
      "name": "only dots",
      "args": [
        [
          ".",
          ".",
          "."
        ]
      ],
      "expected": "/",
      "visibility": "hidden"
    },
    {
      "name": "only up",
      "args": [
        [
          "..",
          ".."
        ]
      ],
      "expected": "/",
      "visibility": "hidden"
    },
    {
      "name": "nested then up twice",
      "args": [
        [
          "a",
          "b",
          "c",
          "..",
          ".."
        ]
      ],
      "expected": "/a",
      "visibility": "hidden"
    },
    {
      "name": "dot mixed with up",
      "args": [
        [
          "a",
          ".",
          "b",
          "..",
          "c",
          "."
        ]
      ],
      "expected": "/a/c",
      "visibility": "hidden"
    },
    {
      "name": "single name",
      "args": [
        [
          "home"
        ]
      ],
      "expected": "/home",
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "simplify_folder_steps",
      "starterPath": "problems/simplify-folder-steps/solutions/python/starter.py",
      "referencePath": "problems/simplify-folder-steps/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "simplifyFolderSteps",
      "starterPath": "problems/simplify-folder-steps/solutions/typescript/starter.ts",
      "referencePath": "problems/simplify-folder-steps/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "SimplifyFolderSteps",
      "starterPath": "problems/simplify-folder-steps/solutions/go/starter.go",
      "referencePath": "problems/simplify-folder-steps/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "simplifyFolderSteps",
      "starterPath": "problems/simplify-folder-steps/solutions/scala/starter.scala",
      "referencePath": "problems/simplify-folder-steps/solutions/scala/reference.scala"
    }
  }
}
