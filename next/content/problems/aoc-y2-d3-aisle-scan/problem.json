    },
    "scala": {
      "entrypoint": "scan_aisle",
      "starterPath": "problems/aoc-y2-d3-aisle-scan/solutions/scala/starter.scala",
      "referencePath": "problems/aoc-y2-d3-aisle-scan/solutions/scala/reference.scala"
    }
  }
}
