          "referencePath": "problems/aoc-y1-d3-slope-walk/parts/part-2-many-slopes/solutions/go/reference.go"
        },
        "scala": {
          "entrypoint": "slope_walk_product",
          "starterPath": "problems/aoc-y1-d3-slope-walk/parts/part-2-many-slopes/solutions/scala/starter.scala",
          "referencePath": "problems/aoc-y1-d3-slope-walk/parts/part-2-many-slopes/solutions/scala/reference.scala"
        }
      }
    }
  ],
