{
  "id": "two-pointers-sliding-window-bonus-03",
  "kind": "problem",
  "title": "Remove Element In Place",
  "difficulty": "easy",
  "concepts": [
    "two-pointers-sliding-window",
    "same-direction pointers"
  ],
  "prompt": "Compact the list in place so that every occurrence of val is dropped and the surviving values fill the front of the list in their original order. Return the count of surviving values; whatever sits past that count does not matter.",
  "signature": {
    "name": "removeElement",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "value",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "removes threes",
      "args": [
        [
          3,
          2,
          2,
          3
        ],
        3
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "scattered target",
      "args": [
        [
          0,
          1,
          2,
          2,
          3,
          0,
          4,
          2
        ],
        2
      ],
      "expected": 5,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        1
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "no match",
      "args": [
        [
          1,
          2,
          3
        ],
        9
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "all match",
      "args": [
        [
          4,
          4,
          4
        ],
        4
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single kept",
      "args": [
        [
          7
        ],
        2
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "single removed",
      "args": [
        [
          2
        ],
        2
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -1,
          0,
          -1,
          5
        ],
        -1
      ],
      "expected": 2,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "remove_element",
      "starterPath": "problems/two-pointers-sliding-window-bonus-03/solutions/python/starter.py",
      "referencePath": "problems/two-pointers-sliding-window-bonus-03/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "removeElement",
      "starterPath": "problems/two-pointers-sliding-window-bonus-03/solutions/typescript/starter.ts",
      "referencePath": "problems/two-pointers-sliding-window-bonus-03/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "RemoveElement",
      "starterPath": "problems/two-pointers-sliding-window-bonus-03/solutions/go/starter.go",
      "referencePath": "problems/two-pointers-sliding-window-bonus-03/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "removeElement",
      "starterPath": "problems/two-pointers-sliding-window-bonus-03/solutions/scala/starter.scala",
      "referencePath": "problems/two-pointers-sliding-window-bonus-03/solutions/scala/reference.scala"
    }
  }
}
