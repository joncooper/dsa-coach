{
  "id": "foundations-bonus-07",
  "kind": "problem",
  "title": "First Negative Index",
  "difficulty": "warmup",
  "concepts": [
    "foundations",
    "iteration",
    "first occurrence"
  ],
  "prompt": "Return the index of the first negative number in the list. If the list contains no negative number, return -1.",
  "signature": {
    "name": "firstNegativeIndex",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "negative in middle",
      "args": [
        [
          3,
          1,
          -2,
          5
        ]
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "no negatives",
      "args": [
        [
          1,
          2,
          3
        ]
      ],
      "expected": -1,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": -1,
      "visibility": "hidden"
    },
    {
      "name": "single negative",
      "args": [
        [
          -9
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "zero is not negative",
      "args": [
        [
          0,
          0,
          -1
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "negative first",
      "args": [
        [
          -1,
          -2
        ]
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "all positive",
      "args": [
        [
          5,
          4,
          3,
          2,
          1
        ]
      ],
      "expected": -1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "first_negative_index",
      "starterPath": "problems/foundations-bonus-07/solutions/python/starter.py",
      "referencePath": "problems/foundations-bonus-07/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "firstNegativeIndex",
      "starterPath": "problems/foundations-bonus-07/solutions/typescript/starter.ts",
      "referencePath": "problems/foundations-bonus-07/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "FirstNegativeIndex",
      "starterPath": "problems/foundations-bonus-07/solutions/go/starter.go",
      "referencePath": "problems/foundations-bonus-07/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "firstNegativeIndex",
      "starterPath": "problems/foundations-bonus-07/solutions/scala/starter.scala",
      "referencePath": "problems/foundations-bonus-07/solutions/scala/reference.scala"
    }
  }
}
