{
  "id": "foundations-bonus-08",
  "kind": "problem",
  "title": "Sum Of Even Indices",
  "difficulty": "easy",
  "concepts": [
    "foundations",
    "indexing",
    "iteration"
  ],
  "prompt": "Return the sum of the values stored at even indices (0, 2, 4, ...) of the list. Index parity is what matters, not the values.",
  "signature": {
    "name": "sumEvenIndices",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "five values",
      "args": [
        [
          10,
          20,
          30,
          40,
          50
        ]
      ],
      "expected": 90,
      "visibility": "visible"
    },
    {
      "name": "four values",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          7
        ]
      ],
      "expected": 7,
      "visibility": "hidden"
    },
    {
      "name": "two values",
      "args": [
        [
          1,
          100
        ]
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -1,
          -1,
          -1,
          -1,
          -1
        ]
      ],
      "expected": -3,
      "visibility": "hidden"
    },
    {
      "name": "three values",
      "args": [
        [
          5,
          5,
          5
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "sum_even_indices",
      "starterPath": "problems/foundations-bonus-08/solutions/python/starter.py",
      "referencePath": "problems/foundations-bonus-08/solutions/python/reference.py"
    },
    "typescript": {
