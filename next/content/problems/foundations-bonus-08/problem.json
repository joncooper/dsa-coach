      "starterPath": "problems/foundations-bonus-08/solutions/typescript/starter.ts",
      "referencePath": "problems/foundations-bonus-08/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "SumEvenIndices",
      "starterPath": "problems/foundations-bonus-08/solutions/go/starter.go",
      "referencePath": "problems/foundations-bonus-08/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "sumEvenIndices",
      "starterPath": "problems/foundations-bonus-08/solutions/scala/starter.scala",
      "referencePath": "problems/foundations-bonus-08/solutions/scala/reference.scala"
    }
  }
}
