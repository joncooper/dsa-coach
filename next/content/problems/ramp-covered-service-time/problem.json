{
  "id": "ramp-covered-service-time",
  "kind": "problem",
  "title": "Covered Service Time",
  "difficulty": "medium",
  "concepts": [
    "intervals",
    "merge intervals",
    "duration"
  ],
  "prompt": "Imagine you are looking at a service timeline. You have a list of windows when a special rule was active: support coverage, a promotion, double pay, an outage, or any other time-based state.\n\nThe windows may be out of order and may overlap. If two windows overlap, the overlapping time should only be counted once.\n\nEach window is `[start, end]`, covering the half-open interval `[start, end)`. Write `coveredServiceTime(windows)` so it returns the total number of time units covered by at least one window.\n\nFor example, `[[1, 5], [2, 6], [8, 10]]` covers `[1, 6)` and `[8, 10)`, so the answer is `7`.\n\nTouching windows have no gap between them. `[[0, 3], [3, 5]]` covers `5` total time units, not `6`, and not two separate chunks that matter for the answer.\n\nIf the input is empty, return `0`.",
  "signature": {
    "name": "coveredServiceTime",
    "inputs": [
      {
        "name": "windows",
        "type": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "overlap counts once",
      "args": [
        [
          [
            1,
            5
          ],
          [
            2,
            6
          ],
          [
            8,
            10
          ]
        ]
      ],
      "expected": 7,
      "visibility": "visible"
    },
    {
      "name": "touching windows",
      "args": [
        [
          [
            0,
            3
          ],
          [
            3,
            5
          ],
          [
            5,
            8
          ]
        ]
      ],
      "expected": 8,
      "visibility": "visible"
    },
    {
      "name": "empty input",
      "args": [
        []
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "nested windows",
      "args": [
        [
          [
            1,
            10
          ],
          [
            2,
            3
          ],
          [
            4,
            8
          ]
        ]
      ],
      "expected": 9,
      "visibility": "hidden"
    },
    {
      "name": "unsorted negative timestamps",
      "args": [
        [
          [
            -3,
            1
          ],
          [
            5,
            7
          ],
          [
            0,
            6
          ]
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "duplicate windows",
      "args": [
        [
          [
            1,
            4
          ],
          [
            1,
            4
          ],
          [
            2,
            3
          ]
        ]
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "separate chunks",
      "args": [
        [
          [
            10,
            12
          ],
          [
            1,
            4
          ],
          [
            6,
            8
          ],
          [
            3,
            5
          ]
        ]
      ],
      "expected": 8,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "covered_service_time",
      "starterPath": "problems/ramp-covered-service-time/solutions/python/starter.py",
      "referencePath": "problems/ramp-covered-service-time/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "coveredServiceTime",
      "starterPath": "problems/ramp-covered-service-time/solutions/typescript/starter.ts",
      "referencePath": "problems/ramp-covered-service-time/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CoveredServiceTime",
      "starterPath": "problems/ramp-covered-service-time/solutions/go/starter.go",
      "referencePath": "problems/ramp-covered-service-time/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "coveredServiceTime",
      "starterPath": "problems/ramp-covered-service-time/solutions/scala/starter.scala",
      "referencePath": "problems/ramp-covered-service-time/solutions/scala/reference.scala"
    }
  }
}
