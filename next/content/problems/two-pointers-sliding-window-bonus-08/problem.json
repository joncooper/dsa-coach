{
  "id": "two-pointers-sliding-window-bonus-08",
  "kind": "problem",
  "title": "Count Pairs Below A Threshold",
  "difficulty": "medium",
  "concepts": [
    "two-pointers-sliding-window",
    "opposite pointers",
    "sorted array"
  ],
  "prompt": "Return how many unordered pairs of distinct positions have a value sum strictly less than threshold.",
  "signature": {
    "name": "countPairsBelow",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "threshold",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "small list",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        5
      ],
      "expected": 2,
      "visibility": "visible"
    },
    {
      "name": "all pairs qualify",
      "args": [
        [
          1,
          1,
          1
        ],
        3
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        5
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          10
        ],
        5
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "equal sum excluded",
      "args": [
        [
          5,
          5
        ],
        5
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -2,
          0,
          3,
          5
        ],
        4
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "every pair under",
      "args": [
        [
          1,
          2,
          3,
          4,
          5,
          6
        ],
        7
      ],
      "expected": 6,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_pairs_below",
      "starterPath": "problems/two-pointers-sliding-window-bonus-08/solutions/python/starter.py",
      "referencePath": "problems/two-pointers-sliding-window-bonus-08/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countPairsBelow",
      "starterPath": "problems/two-pointers-sliding-window-bonus-08/solutions/typescript/starter.ts",
      "referencePath": "problems/two-pointers-sliding-window-bonus-08/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountPairsBelow",
      "starterPath": "problems/two-pointers-sliding-window-bonus-08/solutions/go/starter.go",
      "referencePath": "problems/two-pointers-sliding-window-bonus-08/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countPairsBelow",
      "starterPath": "problems/two-pointers-sliding-window-bonus-08/solutions/scala/starter.scala",
      "referencePath": "problems/two-pointers-sliding-window-bonus-08/solutions/scala/reference.scala"
    }
  }
}
