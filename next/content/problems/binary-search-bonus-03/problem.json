{
  "id": "binary-search-bonus-03",
  "kind": "problem",
  "title": "Count Target Occurrences",
  "difficulty": "easy",
  "concepts": [
    "binary-search",
    "boundary",
    "lower bound"
  ],
  "prompt": "Given a list of integers sorted in non-decreasing order, return how many times target appears. The answer must be computed in logarithmic time.",
  "signature": {
    "name": "countOccurrences",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "target",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "three copies",
      "args": [
        [
          1,
          2,
          2,
          2,
          3
        ],
        2
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "absent",
      "args": [
        [
          1,
          2,
          3,
          4
        ],
        5
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        [],
        1
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "single match",
      "args": [
        [
          4
        ],
        4
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "single miss",
      "args": [
        [
          4
        ],
        7
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "all equal target",
      "args": [
        [
          6,
          6,
          6,
          6
        ],
        6
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "at the front",
      "args": [
        [
          2,
          2,
          5,
          9
        ],
        2
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "at the end",
      "args": [
        [
          1,
          4,
          8,
          8
        ],
        8
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "gap value absent",
      "args": [
        [
          1,
          3,
          5,
          7
        ],
        4
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "negatives",
      "args": [
        [
          -3,
          -3,
          -1,
          0
        ],
        -3
      ],
      "expected": 2,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "count_occurrences",
      "starterPath": "problems/binary-search-bonus-03/solutions/python/starter.py",
      "referencePath": "problems/binary-search-bonus-03/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "countOccurrences",
      "starterPath": "problems/binary-search-bonus-03/solutions/typescript/starter.ts",
      "referencePath": "problems/binary-search-bonus-03/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "CountOccurrences",
      "starterPath": "problems/binary-search-bonus-03/solutions/go/starter.go",
      "referencePath": "problems/binary-search-bonus-03/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "countOccurrences",
      "starterPath": "problems/binary-search-bonus-03/solutions/scala/starter.scala",
      "referencePath": "problems/binary-search-bonus-03/solutions/scala/reference.scala"
    }
  }
}
