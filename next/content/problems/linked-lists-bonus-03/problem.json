{
  "id": "linked-lists-bonus-03",
  "kind": "problem",
  "title": "Maximum List Value",
  "difficulty": "warmup",
  "concepts": [
    "linked-lists",
    "traversal",
    "running state"
  ],
  "prompt": "Given the head of a singly linked list of integers, return the largest value in the list. Return None if the list is empty.",
  "signature": {
    "name": "maxListValue",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "number",
      "nullable": true
    }
  },
  "tests": [
    {
      "name": "peak in middle",
      "args": [
        [
          3,
          9,
          2,
          7
        ]
      ],
      "expected": 9,
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": null,
      "visibility": "visible"
    },
    {
      "name": "single",
      "args": [
        [
          5
        ]
      ],
      "expected": 5,
      "visibility": "hidden"
    },
    {
      "name": "two nodes",
      "args": [
        [
          1,
          2
        ]
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "all negative",
      "args": [
        [
          -5,
          -2,
          -9
        ]
      ],
      "expected": -2,
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          4,
          4,
          4
        ]
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "max at head",
      "args": [
        [
          10,
          1,
          2,
          3
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "max at tail",
      "args": [
        [
          1,
          2,
          3,
          10
        ]
      ],
      "expected": 10,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "max_list_value",
      "starterPath": "problems/linked-lists-bonus-03/solutions/python/starter.py",
      "referencePath": "problems/linked-lists-bonus-03/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "maxListValue",
      "starterPath": "problems/linked-lists-bonus-03/solutions/typescript/starter.ts",
      "referencePath": "problems/linked-lists-bonus-03/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MaxListValue",
      "starterPath": "problems/linked-lists-bonus-03/solutions/go/starter.go",
      "referencePath": "problems/linked-lists-bonus-03/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "maxListValue",
      "starterPath": "problems/linked-lists-bonus-03/solutions/scala/starter.scala",
      "referencePath": "problems/linked-lists-bonus-03/solutions/scala/reference.scala"
    }
  }
}
