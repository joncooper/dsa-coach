{
  "id": "dynamic-programming-bonus-06",
  "kind": "problem",
  "title": "Longest Common Subsequence",
  "difficulty": "medium",
  "concepts": [
    "dynamic-programming",
    "string pair",
    "tabulation"
  ],
  "prompt": "Given two strings, return the length of their longest common subsequence — the longest sequence of characters that appears in both strings in the same relative order, though not necessarily contiguously.",
  "signature": {
    "name": "longestCommonSubsequence",
    "inputs": [
      {
        "name": "a",
        "type": {
          "type": "string"
        }
      },
      {
        "name": "b",
        "type": {
          "type": "string"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "scattered match",
      "args": [
        "abcde",
        "ace"
      ],
      "expected": 3,
      "visibility": "visible"
    },
    {
      "name": "no common letters",
      "args": [
        "abc",
        "def"
      ],
      "expected": 0,
      "visibility": "visible"
    },
    {
      "name": "both empty",
      "args": [
        "",
        ""
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "first empty",
      "args": [
        "",
        "abc"
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "second empty",
      "args": [
        "abc",
        ""
      ],
      "expected": 0,
      "visibility": "hidden"
    },
    {
      "name": "identical",
      "args": [
        "abc",
        "abc"
      ],
      "expected": 3,
      "visibility": "hidden"
    },
    {
      "name": "repeated capped by shorter",
      "args": [
        "aaaa",
        "aa"
      ],
      "expected": 2,
      "visibility": "hidden"
    },
    {
      "name": "subsequence in middle",
      "args": [
        "abcba",
        "bcb"
      ],
      "expected": 3,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "longest_common_subsequence",
      "starterPath": "problems/dynamic-programming-bonus-06/solutions/python/starter.py",
      "referencePath": "problems/dynamic-programming-bonus-06/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "longestCommonSubsequence",
      "starterPath": "problems/dynamic-programming-bonus-06/solutions/typescript/starter.ts",
      "referencePath": "problems/dynamic-programming-bonus-06/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "LongestCommonSubsequence",
      "starterPath": "problems/dynamic-programming-bonus-06/solutions/go/starter.go",
      "referencePath": "problems/dynamic-programming-bonus-06/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "longestCommonSubsequence",
      "starterPath": "problems/dynamic-programming-bonus-06/solutions/scala/starter.scala",
      "referencePath": "problems/dynamic-programming-bonus-06/solutions/scala/reference.scala"
    }
  }
}
