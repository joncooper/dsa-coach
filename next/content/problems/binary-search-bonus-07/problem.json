{
  "id": "binary-search-bonus-07",
  "kind": "problem",
  "title": "Minimum Eating Speed",
  "difficulty": "medium",
  "concepts": [
    "binary-search",
    "answer search",
    "feasibility"
  ],
  "prompt": "There are piles of bananas with given sizes. At a chosen integer speed the eater finishes one pile per hour, eating that speed many bananas and stopping early when a pile runs out. Return the smallest speed that clears every pile within hours hours.",
  "signature": {
    "name": "minEatingSpeed",
    "inputs": [
      {
        "name": "piles",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      {
        "name": "hours",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "moderate budget",
      "args": [
        [
          3,
          6,
          7,
          11
        ],
        8
      ],
      "expected": 4,
      "visibility": "visible"
    },
    {
      "name": "tight budget",
      "args": [
        [
          30,
          11,
          23,
          4,
          20
        ],
        5
      ],
      "expected": 30,
      "visibility": "visible"
    },
    {
      "name": "single pile exact hours",
      "args": [
        [
          10
        ],
        10
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "single pile one hour",
      "args": [
        [
          10
        ],
        1
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "loose budget",
      "args": [
        [
          30,
          11,
          23,
          4,
          20
        ],
        6
      ],
      "expected": 23,
      "visibility": "hidden"
    },
    {
      "name": "all equal piles",
      "args": [
        [
          4,
          4,
          4,
          4
        ],
        4
      ],
      "expected": 4,
      "visibility": "hidden"
    },
    {
      "name": "ones",
      "args": [
        [
          1,
          1,
          1
        ],
        3
      ],
      "expected": 1,
      "visibility": "hidden"
    },
    {
      "name": "one big pile padded",
      "args": [
        [
          1,
          1,
          100
        ],
        4
      ],
      "expected": 50,
      "visibility": "hidden"
    },
    {
      "name": "abundant hours",
      "args": [
        [
          5,
          8,
          6
        ],
        100
      ],
      "expected": 1,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "min_eating_speed",
      "starterPath": "problems/binary-search-bonus-07/solutions/python/starter.py",
      "referencePath": "problems/binary-search-bonus-07/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "minEatingSpeed",
      "starterPath": "problems/binary-search-bonus-07/solutions/typescript/starter.ts",
      "referencePath": "problems/binary-search-bonus-07/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "MinEatingSpeed",
      "starterPath": "problems/binary-search-bonus-07/solutions/go/starter.go",
      "referencePath": "problems/binary-search-bonus-07/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "minEatingSpeed",
      "starterPath": "problems/binary-search-bonus-07/solutions/scala/starter.scala",
      "referencePath": "problems/binary-search-bonus-07/solutions/scala/reference.scala"
    }
  }
}
