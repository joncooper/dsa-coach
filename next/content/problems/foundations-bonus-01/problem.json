{
  "id": "foundations-bonus-01",
  "kind": "problem",
  "title": "Running Maximum",
  "difficulty": "warmup",
  "concepts": [
    "foundations",
    "iteration",
    "prefix state"
  ],
  "prompt": "Given a list of integers, return a new list where each position holds the maximum of all values seen up to and including that position.",
  "signature": {
    "name": "runningMaximum",
    "inputs": [
      {
        "name": "nums",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "rises and plateaus",
      "args": [
        [
          3,
          1,
          4,
          1,
          5,
          9,
          2
        ]
      ],
      "expected": [
        3,
        3,
        4,
        4,
        5,
        9,
        9
      ],
      "visibility": "visible"
    },
    {
      "name": "all decreasing",
      "args": [
        [
          4,
          3,
          2,
          1
        ]
      ],
      "expected": [
        4,
        4,
        4,
        4
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          5
        ]
      ],
      "expected": [
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "all negative",
      "args": [
        [
          -1,
          -3,
          -2
        ]
      ],
      "expected": [
        -1,
        -1,
        -1
      ],
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          2,
          2,
          2
        ]
      ],
      "expected": [
        2,
        2,
        2
      ],
      "visibility": "hidden"
    },
    {
      "name": "strictly increasing",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": [
        1,
        2,
        3,
        4
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "running_maximum",
      "starterPath": "problems/foundations-bonus-01/solutions/python/starter.py",
      "referencePath": "problems/foundations-bonus-01/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "runningMaximum",
      "starterPath": "problems/foundations-bonus-01/solutions/typescript/starter.ts",
      "referencePath": "problems/foundations-bonus-01/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "RunningMaximum",
      "starterPath": "problems/foundations-bonus-01/solutions/go/starter.go",
      "referencePath": "problems/foundations-bonus-01/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "runningMaximum",
      "starterPath": "problems/foundations-bonus-01/solutions/scala/starter.scala",
      "referencePath": "problems/foundations-bonus-01/solutions/scala/reference.scala"
    }
  }
}
