{
  "id": "linked-lists-bonus-06",
  "kind": "problem",
  "title": "Remove Duplicates From Sorted List",
  "difficulty": "easy",
  "concepts": [
    "linked-lists",
    "in-place updates",
    "pointer rewiring"
  ],
  "prompt": "The input `values` serializes a sorted singly linked list in head-to-tail order. The starter code builds a linked-list `head` from that array. Remove duplicate-value nodes so each value appears once, then return the list serialized head-to-tail.",
  "signature": {
    "name": "dedupSortedList",
    "inputs": [
      {
        "name": "values",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "runs collapse",
      "args": [
        [
          1,
          1,
          2,
          3,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "visible"
    },
    {
      "name": "already unique",
      "args": [
        [
          1,
          2,
          3
        ]
      ],
      "expected": [
        1,
        2,
        3
      ],
      "visibility": "visible"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          5
        ]
      ],
      "expected": [
        5
      ],
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          4,
          4,
          4,
          4
        ]
      ],
      "expected": [
        4
      ],
      "visibility": "hidden"
    },
    {
      "name": "two equal",
      "args": [
        [
          7,
          7
        ]
      ],
      "expected": [
        7
      ],
      "visibility": "hidden"
    },
    {
      "name": "duplicate at tail",
      "args": [
        [
          1,
          2,
          2
        ]
      ],
      "expected": [
        1,
        2
      ],
      "visibility": "hidden"
    },
    {
      "name": "with negatives",
      "args": [
        [
          -2,
          -2,
          -1,
          0,
          0
        ]
      ],
      "expected": [
        -2,
        -1,
        0
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "dedup_sorted_list",
      "starterPath": "problems/linked-lists-bonus-06/solutions/python/starter.py",
      "referencePath": "problems/linked-lists-bonus-06/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "dedupSortedList",
      "starterPath": "problems/linked-lists-bonus-06/solutions/typescript/starter.ts",
      "referencePath": "problems/linked-lists-bonus-06/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "DedupSortedList",
      "starterPath": "problems/linked-lists-bonus-06/solutions/go/starter.go",
      "referencePath": "problems/linked-lists-bonus-06/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "dedupSortedList",
      "starterPath": "problems/linked-lists-bonus-06/solutions/scala/starter.scala",
      "referencePath": "problems/linked-lists-bonus-06/solutions/scala/reference.scala"
    }
  }
}
