{
  "id": "warmer-day-waits",
  "kind": "problem",
  "title": "Warmer Day Waits",
  "difficulty": "medium",
  "concepts": [
    "monotonic stack",
    "next greater"
  ],
  "prompt": "For each temperature, return how many days must pass before a warmer temperature. Use 0 if none occurs.",
  "signature": {
    "name": "warmerDayWaits",
    "inputs": [
      {
        "name": "temperatures",
        "type": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      }
    ],
    "output": {
      "type": "array",
      "items": {
        "type": "number"
      }
    }
  },
  "tests": [
    {
      "name": "classic",
      "args": [
        [
          70,
          71,
          69,
          72
        ]
      ],
      "expected": [
        1,
        2,
        1,
        0
      ],
      "visibility": "visible"
    },
    {
      "name": "decreasing",
      "args": [
        [
          5,
          4,
          3
        ]
      ],
      "expected": [
        0,
        0,
        0
      ],
      "visibility": "visible"
    },
    {
      "name": "equal not warmer",
      "args": [
        [
          5,
          5,
          6
        ]
      ],
      "expected": [
        2,
        1,
        0
      ],
      "visibility": "hidden"
    },
    {
      "name": "empty",
      "args": [
        []
      ],
      "expected": [],
      "visibility": "hidden"
    },
    {
      "name": "single",
      "args": [
        [
          50
        ]
      ],
      "expected": [
        0
      ],
      "visibility": "hidden"
    },
    {
      "name": "strictly increasing",
      "args": [
        [
          1,
          2,
          3,
          4
        ]
      ],
      "expected": [
        1,
        1,
        1,
        0
      ],
      "visibility": "hidden"
    },
    {
      "name": "all equal",
      "args": [
        [
          5,
          5,
          5,
          5
        ]
      ],
      "expected": [
        0,
        0,
        0,
        0
      ],
      "visibility": "hidden"
    },
    {
      "name": "dip then climb",
      "args": [
        [
          73,
          74,
          75,
          71,
          69,
          72,
          76,
          73
        ]
      ],
      "expected": [
        1,
        1,
        4,
        2,
        1,
        1,
        0,
        0
      ],
      "visibility": "hidden"
    },
    {
      "name": "late warmer",
      "args": [
        [
          60,
          60,
          60,
          61
        ]
      ],
      "expected": [
        3,
        2,
        1,
        0
      ],
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "warmer_day_waits",
      "starterPath": "problems/warmer-day-waits/solutions/python/starter.py",
      "referencePath": "problems/warmer-day-waits/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "warmerDayWaits",
      "starterPath": "problems/warmer-day-waits/solutions/typescript/starter.ts",
      "referencePath": "problems/warmer-day-waits/solutions/typescript/reference.ts"
    },
    "go": {
      "entrypoint": "WarmerDayWaits",
      "starterPath": "problems/warmer-day-waits/solutions/go/starter.go",
      "referencePath": "problems/warmer-day-waits/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "warmerDayWaits",
      "starterPath": "problems/warmer-day-waits/solutions/scala/starter.scala",
      "referencePath": "problems/warmer-day-waits/solutions/scala/reference.scala"
    }
  }
}
