{
  "id": "foundations-bonus-06",
  "kind": "problem",
  "title": "Greatest Common Divisor",
  "difficulty": "easy",
  "concepts": [
    "foundations",
    "recursion",
    "integer math"
  ],
  "prompt": "Return the greatest common divisor of two non-negative integers using the recursive Euclidean algorithm.",
  "signature": {
    "name": "gcd",
    "inputs": [
      {
        "name": "a",
        "type": {
          "type": "number"
        }
      },
      {
        "name": "b",
        "type": {
          "type": "number"
        }
      }
    ],
    "output": {
      "type": "number"
    }
  },
  "tests": [
    {
      "name": "common factor six",
      "args": [
        12,
        18
      ],
      "expected": 6,
      "visibility": "visible"
    },
    {
      "name": "coprime",
      "args": [
        17,
        5
      ],
      "expected": 1,
      "visibility": "visible"
    },
    {
      "name": "multiple",
      "args": [
        100,
        10
      ],
      "expected": 10,
      "visibility": "hidden"
    },
    {
      "name": "zero first",
      "args": [
        0,
        7
      ],
      "expected": 7,
      "visibility": "hidden"
    },
    {
      "name": "zero second",
      "args": [
        7,
        0
      ],
      "expected": 7,
      "visibility": "hidden"
    },
    {
      "name": "shared twelve",
      "args": [
        48,
        36
      ],
      "expected": 12,
      "visibility": "hidden"
    },
    {
      "name": "equal values",
      "args": [
        13,
        13
      ],
      "expected": 13,
      "visibility": "hidden"
    }
  ],
  "languages": {
    "python": {
      "entrypoint": "gcd",
      "starterPath": "problems/foundations-bonus-06/solutions/python/starter.py",
      "referencePath": "problems/foundations-bonus-06/solutions/python/reference.py"
    },
    "typescript": {
      "entrypoint": "gcd",
      "starterPath": "problems/foundations-bonus-06/solutions/typescript/starter.ts",
      "referencePath": "problems/foundations-bonus-06/solutions/typescript/reference.ts"
    },
    "go": {
