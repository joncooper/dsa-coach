      "referencePath": "problems/aoc-y1-d4-manifest-records/solutions/go/reference.go"
    },
    "scala": {
      "entrypoint": "count_complete_records",
      "starterPath": "problems/aoc-y1-d4-manifest-records/solutions/scala/starter.scala",
      "referencePath": "problems/aoc-y1-d4-manifest-records/solutions/scala/reference.scala"
    }
  }
}
