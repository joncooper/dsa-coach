                "GET",
                "2",
                "task_1"
              ]
            ]
          ],
          "expected": [
            "task_1",
            "write docs|5"
          ],
          "visibility": "visible"
        },
        {
          "name": "search priority then creation order",
          "args": [
            [
              [
                "ADD",
                "1",
                "api docs",
                "3"
              ],
              [
                "ADD",
                "2",
                "api retry",
                "5"
              ],
              [
                "ADD",
                "3",
                "api auth",
                "5"
              ],
              [
                "SEARCH",
                "4",
                "api",
                "10"
              ]
            ]
          ],
          "expected": [
            "task_1",
            "task_2",
            "task_3",
            "task_2,task_3,task_1"
          ],
          "visibility": "visible"
        },
        {
          "name": "quota blocks assignment",
          "args": [
            [
              [
                "ADD_USER",
                "1",
                "u1",
                "1"
              ],
              [
                "ADD",
                "2",
                "a",
                "1"
              ],
              [
                "ADD",
                "3",
                "b",
                "1"
