{
  "name": "dsa-coach",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "test:pwa": "playwright test tests/pwa --config=playwright.pwa.config.ts",
    "validate:content": "node --import tsx scripts/validate-content.ts",
    "verify:references": "node --import tsx scripts/verify-reference-solutions.ts"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@mdx-js/react": "^3.1.0",
    "@uiw/react-codemirror": "^4.23.13",
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "pyodide": "^0.26.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite-plugin-static-copy": "^2.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@mdx-js/rollup": "^3.1.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
